@inherits LayoutComponentBase
@inject IConfiguration Configuration
@inject NavigationManager NavManager
@inject LocalScopedDb LocalDbService
@using BadgeFed.Core
@using BadgeFed.Components
@using BadgeFed.Services
<div class="app-shell public-shell">
    <nav class="navbar public-navbar is-spaced">
        <div class="container">
            <div class="navbar-brand">
                <Logo />

                <a role="button" class="navbar-burger @(isMenuActive ? "is-active" : "")" aria-label="menu" aria-expanded="@isMenuActive" data-target="navMenu" @onclick="ToggleMenu">
                    <span aria-hidden="true"></span>
                    <span aria-hidden="true"></span>
                    <span aria-hidden="true"></span>
                </a>
            </div>

            <div id="navMenu" class="navbar-menu @(isMenuActive ? "is-active" : "")">
                <div class="navbar-start">
                    <a class="navbar-item" href="/">
                        <span class="icon"><i class="fas fa-home"></i></span>
                        <span>Home</span>
                    </a>
                    <a class="navbar-item" href="/explore">
                        <span class="icon"><i class="fas fa-award"></i></span>
                        <span>Explore Badges</span>
                    </a>
                    <a class="navbar-item" href="/search">
                        <span class="icon"><i class="fas fa-search"></i></span>
                        <span>Search Grants</span>
                    </a>
                    <a class="navbar-item" href="/pages/how-to-accept-a-badge.html">
                        <span class="icon"><i class="fas fa-hand-holding-heart"></i></span>
                        <span>How to Accept</span>
                    </a>
                    @{ var _instanceDesc = LocalDbService.GetInstanceDescription(); }
                    @if (!string.IsNullOrEmpty(_instanceDesc.ProfileCTAUrl))
                    {
                        <a class="navbar-item" href="@CtaHelper.BuildCtaUrl(_instanceDesc.ProfileCTAUrl, NavManager.Uri)" target="_blank" rel="noopener">
                            <span class="icon"><i class="fas fa-wallet"></i></span>
                            <span>Badge Wallet</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="app-main">
        <section class="section page-section">
            <div class="container page-container">
                @Body
            </div>
        </section>
    </main>

    <footer class="footer app-footer public-footer">
        <div class="container">
            <div class="footer-links">
                <a href="https://www.vocalcat.com" target="_blank" rel="noopener">
                    <span class="icon"><i class="fas fa-globe"></i></span>
                    <span>VocalCat</span>
                </a>
                <a href="https://github.com/tryvocalcat/activitypub-badges" target="_blank" rel="noopener">
                    <span class="icon"><i class="fab fa-github"></i></span>
                    <span>Source Code</span>
                </a>
                <a href="https://badgefed.vocalcat.com/" target="_blank" rel="noopener">
                    <span class="icon"><i class="fas fa-book"></i></span>
                    <span>Documentation</span>
                </a>
            </div>
            <p class="footer-text">
                BadgeFed is an open-source ActivityPub app for issuing, receiving, and verifying badges across the social web.
            </p>
        </div>
    </footer>
</div>

@code {
    private bool isMenuActive = false;

    private void ToggleMenu()
    {
        isMenuActive = !isMenuActive;
    }
}
