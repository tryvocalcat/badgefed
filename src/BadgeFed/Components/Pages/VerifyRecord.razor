@page "/view/grant/{noteIdParam}"
@using ActivityPubDotNet.Core
@using System.Text.Json
@using Markdig

@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager NavManager
@inject LocalScopedDb DbService
@inject BadgeImageService BadgeImageService
@layout BadgeFed.Components.Layouts.MinimalLayout
@inject IJSRuntime JSRuntime

<HeadContent>
  <meta name="author" content="@badgeRecord!.IssuedBy" />
  <meta name="description" content="@badgeRecord.Title was issued by @actorName to @badgeRecord.IssuedToName" />
  <meta property="og:type" content="article" />
  <meta property="og:title" content="@badgeRecord.Title was issued by @actorName to @badgeRecord.IssuedToName" />
  <meta property="og:description" content="@badgeRecord.Description" />
  <meta property="og:url" content="@NavManager.Uri" />
  <meta property="og:image" content="@ogImage" />
  <meta name="fediverse:creator" content="@badgeRecord.IssuerFediverseHandle" />
</HeadContent>

<style>
/* ═══════════════════════════════════════════════════
   VerifyRecord — BadgeFed Design System
   MinimalLayout (no .container wrapper from layout)
   ═══════════════════════════════════════════════════ */

.vr-shell {
    font-family:'Inter',system-ui,-apple-system,sans-serif;
    background:#fff; color:#0f172a;
    min-height:100vh;
}

/* ── Not-found banner ─────────────────────────────── */
.vr-not-found {
    max-width:600px; margin:3rem auto; padding:2rem 2.5rem;
    border:1px dashed #fcd34d; border-radius:18px;
    background:#fffbeb; color:#92400e; text-align:center;
}
.vr-not-found i { font-size:1.8rem; color:#f59e0b; display:block; margin-bottom:.75rem; }
.vr-not-found a { color:#d97706; font-weight:600; }

/* ── Main two-column layout ───────────────────────── */
.vr-layout {
    max-width:960px; margin:0 auto; padding:2rem 1.25rem 4rem;
}

/* ── Grant header card ────────────────────────────── */
.vr-header {
    background:linear-gradient(135deg,#1e1b4b 0%,#312e81 100%);
    border-radius:20px; padding:2rem 2.25rem; margin-bottom:1.5rem;
    position:relative; overflow:hidden; color:#fff;
}
.vr-header::before {
    content:''; position:absolute; inset:0; pointer-events:none;
    background:radial-gradient(ellipse 70% 80% at 100% 0%, rgba(99,102,241,.22) 0%, transparent 60%);
}
.vr-header-inner { position:relative; z-index:1; display:flex; align-items:flex-start; justify-content:space-between; flex-wrap:wrap; gap:1.25rem; }
.vr-verified-pill {
    display:inline-flex; align-items:center; gap:.4rem;
    background:rgba(16,185,129,.15); border:1px solid rgba(16,185,129,.3);
    color:#34d399; border-radius:999px; padding:.3rem .9rem;
    font-size:.72rem; font-weight:700; letter-spacing:.04em;
    text-transform:uppercase; margin-bottom:.75rem;
    cursor:pointer; transition:background .15s, border-color .15s;
}
.vr-verified-pill:hover { background:rgba(16,185,129,.28); border-color:rgba(16,185,129,.55); }
.vr-header-title { font-size:clamp(1.3rem,3vw,1.8rem); font-weight:900; letter-spacing:-.03em; line-height:1.15; margin-bottom:.35rem; }
.vr-header-sub { font-size:.85rem; opacity:.8; }
.vr-header-sub a { color:#a5b4fc; }
.vr-cert-btn {
    flex-shrink:0; display:inline-flex; align-items:center; gap:.4rem;
    background:rgba(255,255,255,.12); border:1.5px solid rgba(255,255,255,.25);
    color:#fff; border-radius:10px; padding:.55rem 1.1rem;
    font-size:.8rem; font-weight:600; cursor:pointer; text-decoration:none;
    transition:background .15s; white-space:nowrap;
    font-family:inherit;
}
.vr-cert-btn:hover { background:rgba(255,255,255,.22); }

/* ── Badge image card ─────────────────────────────── */
.vr-badge-img-card {
    background:#f8fafc; border:1px solid #e2e8f0; border-radius:18px;
    padding:2rem; text-align:center; margin-bottom:1.5rem; position:relative;
    margin: auto;
}
.vr-badge-img { max-height:260px; max-width:100%; object-fit:contain; border-radius:10px; display:block; margin:0 auto; }
.vr-verifiable-pill {
    display:inline-flex; align-items:center; gap:.3rem;
    position:absolute; top:1rem; right:1rem;
    background:rgba(16,185,129,.9); color:#fff;
    border-radius:999px; padding:.25rem .65rem;
    font-size:.67rem; font-weight:700;
    box-shadow:0 2px 8px rgba(0,0,0,.15);
    cursor:pointer; transition:background .15s, box-shadow .15s;
}
.vr-verifiable-pill:hover { background:rgba(5,150,105,1); box-shadow:0 4px 14px rgba(0,0,0,.25); }

/* ── Meta chips ───────────────────────────────────── */
.vr-meta-row { display:flex; flex-wrap:wrap; gap:.5rem; margin-bottom:1.25rem; }
.vr-chip {
    display:inline-flex; align-items:center; gap:.4rem;
    background:#f1f5f9; border:1px solid #e2e8f0; border-radius:10px;
    padding:.45rem .85rem; font-size:.78rem; color:#475569;
}
.vr-chip i { color:#94a3b8; font-size:.7rem; }
.vr-chip a { color:#6366f1; font-weight:600; text-decoration:none; }
.vr-chip.external { background:rgba(245,158,11,.08); border-color:rgba(245,158,11,.25); color:#b45309; }

/* ── Hashtags ─────────────────────────────────────── */
.vr-tags { display:flex; flex-wrap:wrap; gap:.35rem; margin-bottom:1.25rem; }
.vr-tag {
    display:inline-flex; align-items:center; border-radius:999px; padding:.18rem .6rem;
    font-size:.67rem; font-weight:600;
}

/* ── Description + Criteria ──────────────────────── */
.vr-desc { font-size:.9rem; line-height:1.7; color:#475569; margin-bottom:1.5rem; }
.vr-criteria {
    background:#f8fafc; border:1px solid #e2e8f0; border-radius:16px;
    padding:1.4rem 1.6rem; margin-bottom:1.5rem;
}
.vr-criteria-title { font-size:.8rem; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#94a3b8; margin-bottom:.75rem; display:flex; align-items:center; gap:.4rem; }
.vr-criteria-body { font-size:.85rem; line-height:1.7; color:#475569; }
.vr-criteria-body p { margin-bottom:.5rem; }
.vr-learn-btn {
    display:inline-flex; align-items:center; gap:.35rem; margin-top:.75rem;
    background:rgba(6,182,212,.08); border:1px solid rgba(6,182,212,.22);
    color:#0891b2; border-radius:8px; padding:.35rem .85rem;
    font-size:.75rem; font-weight:600; text-decoration:none; transition:background .15s;
}
.vr-learn-btn:hover { background:rgba(6,182,212,.15); }

/* ── Security / actions card ──────────────────────── */
.vr-security {
    background:#fff; border:1px solid #e2e8f0; border-radius:16px;
    padding:1.4rem 1.6rem; margin-bottom:1.5rem;
}
.vr-security-title { font-size:.8rem; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#94a3b8; margin-bottom:1rem; display:flex; align-items:center; gap:.4rem; }
.vr-action-row { display:flex; flex-wrap:wrap; gap:.6rem; margin-bottom:.85rem; }
.vr-btn {
    display:inline-flex; align-items:center; gap:.35rem;
    border-radius:10px; padding:.5rem 1rem; font-size:.78rem; font-weight:600;
    cursor:pointer; text-decoration:none; transition:background .15s, opacity .15s;
    border:none; font-family:inherit; white-space:nowrap;
}
.vr-btn.verify { background:linear-gradient(135deg,#10b981,#059669); color:#fff; }
.vr-btn.verify:hover { opacity:.88; }
.vr-btn.download { background:rgba(99,102,241,.08); border:1px solid rgba(99,102,241,.22); color:#6366f1; }
.vr-btn.download:hover { background:rgba(99,102,241,.15); }
.vr-btn.secondary { background:#f8fafc; border:1px solid #e2e8f0; color:#475569; }
.vr-btn.secondary:hover { background:#f1f5f9; }
.vr-hint { font-size:.75rem; color:#94a3b8; line-height:1.6; }
.vr-hint a { color:#6366f1; }

/* ── Owner actions card ───────────────────────────── */
.vr-owner {
    background:#fff; border:1px solid #e2e8f0; border-radius:16px;
    padding:1.4rem 1.6rem; margin-bottom:1.5rem;
}
.vr-owner-title { font-size:.8rem; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#94a3b8; margin-bottom:1rem; display:flex; align-items:center; gap:.4rem; }
.vr-owner-grid { display:flex; flex-wrap:wrap; gap:.6rem; }
.vr-share-btn {
    display:inline-flex; align-items:center; gap:.4rem;
    border-radius:10px; padding:.5rem 1rem; font-size:.78rem; font-weight:600;
    cursor:pointer; text-decoration:none; border:1.5px solid; background:#fff;
    transition:background .15s, color .15s; white-space:nowrap;
}
.vr-share-btn.mastodon  { border-color:#6364ff; color:#6364ff; }
.vr-share-btn.mastodon:hover  { background:#6364ff; color:#fff; }
.vr-share-btn.linkedin  { border-color:#0a66c2; color:#0a66c2; }
.vr-share-btn.linkedin:hover  { background:#0a66c2; color:#fff; }

/* ── External warning ─────────────────────────────── */
.vr-external-warn {
    background:rgba(245,158,11,.07); border:1px solid rgba(245,158,11,.25);
    border-radius:14px; padding:1rem 1.25rem; margin-bottom:1.5rem;
    font-size:.83rem; color:#92400e; display:flex; align-items:center; gap:.75rem; flex-wrap:wrap;
}
.vr-external-warn i { color:#f59e0b; font-size:1rem; flex-shrink:0; }
.vr-external-warn a { color:#6366f1; font-weight:600; }

/* ── Comments card ────────────────────────────────── */
.vr-comments { background:#fff; border:1px solid #e2e8f0; border-radius:16px; padding:1.4rem 1.6rem; margin-bottom:1.5rem; }
.vr-comments-title { font-size:.8rem; font-weight:700; text-transform:uppercase; letter-spacing:.07em; color:#94a3b8; margin-bottom:.6rem; display:flex; align-items:center; gap:.4rem; }
.vr-comments-intro { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:.75rem; margin-bottom:1.1rem; }
.vr-comments-intro p { font-size:.82rem; color:#64748b; margin:0; }
.vr-copy-btn {
    display:inline-flex; align-items:center; gap:.3rem;
    background:#f8fafc; border:1px solid #e2e8f0; color:#64748b;
    border-radius:8px; padding:.3rem .75rem; font-size:.73rem; font-weight:600;
    cursor:pointer; font-family:inherit; transition:background .15s;
}
.vr-copy-btn:hover { background:#f1f5f9; }
.vr-comments-empty { text-align:center; padding:2rem; color:#94a3b8; }
.vr-comments-empty i { font-size:1.5rem; display:block; margin-bottom:.5rem; color:#e2e8f0; }
.vr-comments-empty p { font-size:.83rem; }
.comment-card { background:#f8fafc; border:1px solid #f1f5f9; border-radius:12px; padding:1rem 1.1rem; margin-bottom:.6rem; }
.comment-header { display:flex; align-items:center; gap:.65rem; margin-bottom:.6rem; }
.comment-avatar { width:34px; height:34px; border-radius:50%; overflow:hidden; background:#e2e8f0; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.comment-avatar img { width:100%; height:100%; object-fit:cover; border-radius:50%; }
.comment-author { font-size:.82rem; font-weight:700; color:#0f172a; }
.comment-date   { font-size:.72rem; color:#94a3b8; }
.comment-content { font-size:.83rem; color:#475569; line-height:1.6; }

/* ── Fingerprint block ────────────────────────────── */
.vr-fingerprint {
    font-family:'Inconsolata','Courier New',monospace;
    background:#0f172a; color:#10b981; border-radius:10px;
    padding:.85rem 1rem; font-size:.78rem; word-break:break-all; margin-top:.5rem;
}

/* ── Verification modal ───────────────────────────── */
.verification-modal {
    display:none; position:fixed; inset:0; z-index:10000;
    background:rgba(0,0,0,.7); backdrop-filter:blur(4px);
}
.verification-modal.show {
    display:flex; align-items:center; justify-content:center;
    animation:vr-fadein .25s ease;
}
.verification-modal-content {
    background:#fff; border-radius:20px; width:90%; max-width:680px;
    max-height:90vh; overflow-y:auto; box-shadow:0 24px 64px rgba(0,0,0,.25);
    animation:vr-slideup .25s ease;
}
.verification-modal-header {
    background:linear-gradient(135deg,#10b981,#059669);
    color:#fff; padding:1.75rem 2rem; border-radius:20px 20px 0 0;
    display:flex; align-items:center; justify-content:space-between; position:relative;
}
.verification-modal-title { font-size:1.25rem; font-weight:800; display:flex; align-items:center; gap:.5rem; margin:0; }
.verification-close {
    background:rgba(255,255,255,.2); border:none; color:#fff;
    width:36px; height:36px; border-radius:50%; cursor:pointer;
    display:flex; align-items:center; justify-content:center; font-size:1rem;
    transition:background .15s; font-family:inherit;
}
.verification-close:hover { background:rgba(255,255,255,.32); }
.verification-modal-body { padding:1.75rem 2rem; }
.verification-modal-body>p { text-align:center; font-size:.83rem; color:#64748b; margin-bottom:1.5rem; }

/* trust factor rows */
.trust-factor {
    display:flex; align-items:flex-start; gap:.85rem;
    padding:1.1rem 1.25rem 1.1rem 1rem;
    border:1.5px solid #e2e8f0; border-radius:14px; margin-bottom:.75rem;
    position:relative; transition:border-color .15s, box-shadow .15s;
}
.trust-factor:hover { border-color:#a7f3d0; box-shadow:0 3px 12px rgba(16,185,129,.08); }
.trust-factor-check {
    flex-shrink:0; width:30px; height:30px; border-radius:50%;
    background:linear-gradient(135deg,#10b981,#059669);
    display:flex; align-items:center; justify-content:center; color:#fff; font-size:.85rem;
}
.trust-factor-content { flex:1; min-width:0; }
.trust-factor-title { font-size:.88rem; font-weight:700; color:#0f172a; margin:0 0 .3rem; }
.trust-factor-description { font-size:.78rem; color:#64748b; line-height:1.5; margin:0; }
.trust-factor-description small { color:#94a3b8; font-style:italic; display:block; margin-top:.2rem; }
.trust-factor-value {
    background:#f8fafc; border-left:3px solid #10b981; border-radius:6px;
    padding:.5rem .65rem; margin-top:.5rem;
    font-family:'Inconsolata','Courier New',monospace; font-size:.76rem; color:#334155; word-break:break-all;
}
.trust-factor-value a { color:#10b981; text-decoration:none; }

/* tooltip */
.trust-factor-help { position:absolute; top:.85rem; right:.85rem; }
.tooltip { position:relative; display:inline-block; }
.tooltip .tooltiptext {
    visibility:hidden; width:280px; background:#1e293b; color:#e2e8f0;
    border-radius:10px; padding:.65rem .85rem; position:absolute; z-index:10001;
    bottom:130%; right:0; font-size:.75rem; line-height:1.45; box-shadow:0 4px 16px rgba(0,0,0,.25);
    opacity:0; transition:opacity .2s; pointer-events:none;
}
.tooltip .tooltiptext::after { content:''; position:absolute; top:100%; right:16px; border:7px solid transparent; border-top-color:#1e293b; }
.tooltip:hover .tooltiptext { visibility:visible; opacity:1; }

/* modal footer */
.vr-modal-footer { margin-top:1.5rem; padding-top:1.25rem; border-top:1px solid #f1f5f9; text-align:center; font-size:.78rem; color:#94a3b8; }
.vr-modal-footer i { color:#10b981; }

/* ── Certificate modal ────────────────────────────── */
.certificate-modal { display:none; position:fixed; inset:0; z-index:10000; background:rgba(0,0,0,.8); overflow:auto; }
.certificate-modal.show { display:block; }
.modal-content { position:relative; background:#fff; margin:2% auto; width:95%; max-width:1100px; border-radius:12px; box-shadow:0 20px 60px rgba(0,0,0,.3); max-height:95vh; overflow-y:auto; }
.modal-header { display:flex; justify-content:space-between; align-items:center; padding:.85rem 1.5rem; background:#1e1b4b; color:#fff; border-radius:12px 12px 0 0; gap:1rem; }
.modal-title { margin:0; font-size:1rem; font-weight:700; }
.modal-actions { display:flex; gap:.6rem; align-items:center; }
.modal-button { display:flex; align-items:center; gap:.35rem; padding:.4rem .85rem; border:none; border-radius:8px; cursor:pointer; font-size:.77rem; font-weight:600; text-decoration:none; transition:opacity .15s; font-family:inherit; }
.print-button { background:#10b981; color:#fff; }
.print-button:hover { opacity:.88; }
.close-button { background:transparent; color:#fff; border:1.5px solid rgba(255,255,255,.4); }
.close-button:hover { background:rgba(255,255,255,.1); }
.modal-body { padding:0; }

/* Certificate layout */
.certificate-container { max-width:1100px; margin:0 auto; background:#f8f9ff; border:6px solid #1e1b4b; position:relative; overflow:hidden; }
.certificate-container::after { content:''; position:absolute; inset:24px; border:1px solid #1e1b4b; pointer-events:none; z-index:2; }
.certificate-header { text-align:center; padding:2.5rem 3rem 1.5rem; position:relative; z-index:3; }
.certificate-title { font-family:'Times New Roman',serif; font-size:3rem; font-weight:normal; color:#1e1b4b; letter-spacing:.08em; text-shadow:1px 1px 3px rgba(0,0,0,.15); }
.certificate-subtitle { font-family:'Times New Roman',serif; font-size:1.2rem; color:#553c9a; font-style:italic; margin-top:.25rem; }
.certificate-content { text-align:center; padding:.5rem 2.5rem 1rem; position:relative; z-index:3; }
.certificate-recipient { font-family:'Times New Roman',serif; font-size:1.1rem; color:#2d3748; }
.certificate-recipient-name { font-family:'Times New Roman',serif; font-size:2.2rem; font-weight:bold; color:#1e1b4b; border-bottom:2px solid #1e1b4b; display:inline-block; padding-bottom:4px; margin:.25rem 0 .5rem; }
.certificate-achievement { font-family:'Times New Roman',serif; font-size:1.1rem; color:#4a5568; }
.certificate-badge-title { font-family:'Times New Roman',serif; font-size:1.7rem; font-weight:bold; color:#1e1b4b; text-transform:uppercase; letter-spacing:.12em; margin:.4rem 0; }
.certificate-description { font-family:'Times New Roman',serif; font-size:1rem; color:#4a5568; max-width:700px; margin:1rem auto; line-height:1.65; }
.certificate-footer { display:flex; justify-content:space-between; align-items:flex-end; padding:1rem 3rem 1.5rem; position:relative; z-index:3; }
.certificate-issuer, .certificate-date { flex:1; }
.certificate-issuer { text-align:left; }
.certificate-date { text-align:right; }
.certificate-seal { flex:1; display:flex; align-items:center; justify-content:center; }
.certificate-issuer-name, .certificate-date-value { font-family:'Times New Roman',serif; font-size:1.1rem; font-weight:bold; color:#1e1b4b; border-bottom:2px solid #1e1b4b; padding-bottom:4px; display:inline-block; }
.certificate-issuer-title, .certificate-date-label { font-family:'Times New Roman',serif; font-size:.78rem; color:#718096; text-transform:uppercase; letter-spacing:1px; margin-top:.25rem; }
.certificate-seal-image { width:100px; height:100px; border-radius:50%; border:2px solid #1e1b4b; object-fit:contain; background:#fff; padding:8px; }
.certificate-ornament { position:absolute; font-size:1.6rem; color:#1e1b4b; opacity:.3; z-index:3; }
.certificate-ornament.top-left    { top:42px; left:42px; }
.certificate-ornament.top-right   { top:42px; right:42px; }
.certificate-ornament.bottom-left { bottom:42px; left:42px; }
.certificate-ornament.bottom-right{ bottom:42px; right:42px; }
.certificate-verification { background:#f1f5f9; border:1px solid #e2e8f0; border-radius:8px; padding:.6rem 1.5rem; margin:0 4rem 1.5rem; text-align:center; position:relative; z-index:3; }
.certificate-verification-title { font-size:.85rem; font-weight:600; color:#1e1b4b; margin-bottom:.2rem; }
.certificate-verification-text   { font-size:.78rem; color:#64748b; margin-bottom:.3rem; }
.certificate-qr-section { display:flex; justify-content:space-between; align-items:center; gap:1.5rem; }
.certificate-fingerprint-section { flex:1; }
.certificate-fingerprint { font-family:'Inconsolata',monospace; font-size:.72rem; background:#1e1b4b; color:#10b981; padding:.5rem .65rem; border-radius:4px; word-break:break-all; }
.certificate-qr-code { text-align:center; flex-shrink:0; }
.certificate-qr-image { width:72px; height:72px; border:2px solid #1e1b4b; border-radius:4px; background:#fff; padding:3px; }
.certificate-qr-label { font-size:.65rem; color:#64748b; margin-top:.2rem; }
.verification-badge { display:inline-flex; align-items:center; gap:.4rem; background:rgba(16,185,129,.1); color:#10b981; border:1px solid rgba(16,185,129,.2); border-radius:999px; padding:.3rem .85rem; font-size:.72rem; font-weight:700; text-transform:uppercase; letter-spacing:.04em; margin-bottom:1rem; }

/* ── Modal action buttons ─────────────────────────── */
.vr-modal-actions {
    display:flex; flex-wrap:wrap; gap:.6rem; margin-bottom:1.25rem;
}
.vr-modal-divider {
    font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em;
    color:#94a3b8; margin:0 0 1rem; display:flex; align-items:center; gap:.6rem;
}
.vr-modal-divider::before, .vr-modal-divider::after {
    content:''; flex:1; height:1px; background:#e2e8f0;
}

@@keyframes vr-fadein  { from{opacity:0} to{opacity:1} }
@@keyframes vr-slideup { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

@@media (max-width:640px) {
    .vr-header { padding:1.5rem; }
    .verification-modal-body { padding:1.25rem; }
    .certificate-footer { flex-direction:column; gap:1.5rem; text-align:center; }
    .certificate-issuer, .certificate-date { text-align:center; }
    .certificate-verification { margin:0 1rem 1.5rem; }
    .certificate-qr-section { flex-direction:column; }
}

@@media print {
    body * { visibility:hidden; }
    .certificate-modal, .certificate-modal * { visibility:visible; }
    .certificate-modal { position:absolute; inset:0; background:#fff !important; display:block !important; }
    .modal-content { margin:0; width:100%; max-width:none; box-shadow:none; border-radius:0; max-height:none; overflow:visible; }
    .modal-header { display:none !important; }
    .certificate-container { margin:0; box-shadow:none; -webkit-print-color-adjust:exact; color-adjust:exact; }
}
</style>

@if (badgeRecord == null)
{
    <div class="vr-not-found">
        <i class="fas fa-exclamation-triangle"></i>
