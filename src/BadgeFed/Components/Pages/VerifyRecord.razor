                document.body.appendChild(toast);
                setTimeout(() => toast.remove(), 3000);
            }).catch(function() { alert('Failed to copy URL to clipboard'); });
        }
        function openCertificateModal()    { document.getElementById('certificateModal').classList.add('show');    document.body.style.overflow='hidden'; }
