@page "/view/actor/{domain}/{username}"
@page "/view/actor/{username}"

@using System.Linq
@using BadgeFed.Services
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager NavManager
@inject LocalScopedDb DbService
@inject IWebHostEnvironment Environment
@inject ICustomAssetPathService CustomAssetPathService

@if (!string.IsNullOrEmpty(GetThemeCssPath()))
{
    <link rel="stylesheet" href="@GetThemeCssPath()" />
}

<style>
/* ═══════════════════════════════════════════════════
   ViewActor — BadgeFed Design System (token-driven)
   Theme files override --bf-* variables.
   ═══════════════════════════════════════════════════ */

.bf {
    --bf-accent:      #6366f1;
    --bf-accent-alt:  #7c3aed;
    --bf-highlight:   #06b6d4;
    --bf-page-bg:     #fff;
    --bf-page-fg:     #0f172a;
    --bf-card-bg:     #fff;
    --bf-card-border: #e2e8f0;
    --bf-muted:       #64748b;
    --bf-subtle:      #94a3b8;

    background: var(--bf-page-bg);
    color: var(--bf-page-fg);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
}

/* ── Loading / Error ──────────────────────────────── */
.bf-loading-wrap { text-align:center; padding:5rem 1rem; color:var(--bf-subtle); }
.bf-loading-wrap i { font-size:1.6rem; display:block; margin-bottom:.7rem; color:var(--bf-accent); opacity:.4; }
.bf-loading-title { font-size:.95rem; font-weight:600; color:var(--bf-muted); margin-bottom:.25rem; }
.bf-not-found {
    margin:3rem auto; max-width:480px; text-align:center; padding:3rem 2rem;
    border:1px dashed #fcd34d; border-radius:18px; color:#92400e; background:#fffbeb;
}
.bf-not-found i { font-size:1.8rem; color:#f59e0b; display:block; margin-bottom:.75rem; }

/* ── Actor hero banner ────────────────────────────── */
.bf-actor-hero {
    background: linear-gradient(135deg, var(--bf-accent) 0%, var(--bf-accent-alt) 100%);
    color: #fff;
    padding: 3rem 0 2.5rem;
    position: relative;
    overflow: hidden;
}
.bf-actor-hero::before {
    content:'';
    position:absolute; inset:0;
    background: radial-gradient(ellipse 70% 120% at 100% 50%, rgba(255,255,255,.08) 0%, transparent 60%);
    pointer-events:none;
}
.bf-hero-inner {
    display:flex; align-items:flex-start; gap:2rem; flex-wrap:wrap;
    position:relative; z-index:1;
}

/* avatar */
.bf-actor-avatar {
    flex-shrink:0; width:110px; height:110px; border-radius:50%;
    object-fit:cover; border:4px solid rgba(255,255,255,.8);
    box-shadow:0 6px 24px rgba(0,0,0,.18);
}
.bf-actor-avatar-ph {
    flex-shrink:0; width:110px; height:110px; border-radius:50%;
    background:rgba(255,255,255,.15); border:4px solid rgba(255,255,255,.5);
    display:flex; align-items:center; justify-content:center;
    font-size:2.5rem; color:rgba(255,255,255,.85);
}

/* name / summary */
.bf-hero-info { flex:1; min-width:0; padding-top:.35rem; }
.bf-actor-name { font-size:clamp(1.5rem,3vw,2rem); font-weight:900; letter-spacing:-.03em; line-height:1.15; margin-bottom:.35rem; }
.bf-actor-summary { font-size:.88rem; opacity:.88; line-height:1.65; margin-bottom:1.25rem; max-width:560px; }

/* stats strip */
.bf-hero-stats { display:flex; gap:.5rem; flex-wrap:wrap; margin-bottom:1.25rem; }
.bf-hero-stat {
    background:rgba(255,255,255,.15); border:1px solid rgba(255,255,255,.2);
    border-radius:12px; padding:.6rem 1.1rem; text-align:center; min-width:80px;
    backdrop-filter:blur(8px);
}
.bf-hero-stat-num { font-size:1.25rem; font-weight:800; line-height:1; }
.bf-hero-stat-lbl { font-size:.62rem; opacity:.8; text-transform:uppercase; letter-spacing:.06em; margin-top:.2rem; }

/* social links */
.bf-social-links { display:flex; gap:.5rem; flex-wrap:wrap; }
.bf-social-btn {
    width:36px; height:36px; border-radius:50%;
    background:rgba(255,255,255,.15); border:1px solid rgba(255,255,255,.25);
    display:flex; align-items:center; justify-content:center;
    color:#fff; text-decoration:none; font-size:.85rem;
    transition:background .15s;
}
.bf-social-btn:hover { background:rgba(255,255,255,.28); }

/* ── Main body ────────────────────────────────────── */
.bf-body { padding:2.5rem 0 3rem; }

/* ── Section header ───────────────────────────────── */
.bf-section-hd {
    display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap;
    gap:.75rem; margin-bottom:1.5rem;
}
.bf-section-title { font-size:1.05rem; font-weight:800; color:var(--bf-page-fg); }
.bf-section-title span { color:var(--bf-accent); }
.bf-outline-btn {
    display:inline-flex; align-items:center; gap:.35rem;
    background:color-mix(in srgb, var(--bf-accent) 7%, transparent);
    border:1px solid color-mix(in srgb, var(--bf-accent) 22%, transparent);
    color:var(--bf-accent); border-radius:10px;
    padding:.4rem .9rem; font-size:.78rem; font-weight:600; text-decoration:none;
    transition:background .15s;
}
.bf-outline-btn:hover { background:color-mix(in srgb, var(--bf-accent) 14%, transparent); }

/* ── Badge grid ───────────────────────────────────── */
.bf-badge-grid {
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(260px, 1fr));
    gap:1.1rem;
    margin-bottom:2.5rem;
}
.bf-badge-card {
    background:var(--bf-card-bg); border:1px solid var(--bf-card-border); border-radius:18px;
    overflow:hidden; display:flex; flex-direction:column;
    transition:border-color .2s, box-shadow .2s, transform .2s;
}
.bf-badge-card:hover {
    border-color:color-mix(in srgb, var(--bf-accent) 40%, var(--bf-card-border));
    box-shadow:0 6px 28px color-mix(in srgb, var(--bf-accent) 10%, transparent);
    transform:translateY(-2px);
}
.bf-badge-img-zone {
    height:160px; background:color-mix(in srgb, var(--bf-accent) 5%, var(--bf-card-bg));
    display:flex; align-items:center; justify-content:center; padding:1.25rem;
    border-bottom:1px solid var(--bf-card-border);
}
.bf-badge-img { max-height:100%; max-width:100%; object-fit:contain; border-radius:8px; }
.bf-badge-img-ph { font-size:2.5rem; color:var(--bf-accent); opacity:.35; }
.bf-badge-body { padding:1rem 1.1rem 1.1rem; display:flex; flex-direction:column; flex:1; }
.bf-badge-title { font-size:.9rem; font-weight:700; color:var(--bf-page-fg); margin-bottom:.3rem; line-height:1.3; }
.bf-badge-desc  { font-size:.77rem; color:var(--bf-muted); line-height:1.55; flex:1; margin-bottom:.8rem; }
.bf-badge-footer { display:flex; align-items:center; justify-content:space-between; }
.bf-type-pill {
    display:inline-flex; align-items:center; border-radius:999px; padding:.18rem .6rem;
    font-size:.65rem; font-weight:600;
    background:color-mix(in srgb, var(--bf-accent) 10%, transparent);
    color:var(--bf-accent);
    border:1px solid color-mix(in srgb, var(--bf-accent) 20%, transparent);
}
.bf-recipients-btn {
    display:inline-flex; align-items:center; gap:.3rem;
    background:#f8fafc; border:1px solid var(--bf-card-border);
    color:var(--bf-muted); border-radius:8px; padding:.28rem .7rem;
    font-size:.7rem; font-weight:600; text-decoration:none;
    transition:background .15s, border-color .15s, color .15s;
}
.bf-recipients-btn:hover {
    background:color-mix(in srgb, var(--bf-accent) 8%, transparent);
    border-color:color-mix(in srgb, var(--bf-accent) 20%, transparent);
    color:var(--bf-accent);
}

/* ── Followers ────────────────────────────────────── */
.bf-followers-grid {
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(240px, 1fr));
    gap:1rem;
}
.bf-follower-card {
    background:var(--bf-card-bg); border:1px solid var(--bf-card-border);
    border-radius:16px; padding:1rem 1.1rem;
    display:flex; align-items:center; gap:.85rem;
    transition:border-color .18s, transform .18s;
}
.bf-follower-card:hover {
    border-color:color-mix(in srgb, var(--bf-accent) 35%, var(--bf-card-border));
    transform:translateX(3px);
}
.bf-follower-avatar {
    flex-shrink:0; width:44px; height:44px; border-radius:50%;
    object-fit:cover; border:2px solid var(--bf-card-border);
}
.bf-follower-avatar-ph {
    flex-shrink:0; width:44px; height:44px; border-radius:50%;
    display:flex; align-items:center; justify-content:center;
    font-size:.78rem; font-weight:700; color:#fff;
}
.bf-follower-name { font-size:.85rem; font-weight:700; color:var(--bf-page-fg); line-height:1.3; }
.bf-follower-handle {
    display:inline-flex; align-items:center; gap:.2rem; margin-top:.15rem;
    font-size:.7rem; color:var(--bf-subtle); text-decoration:none;
}
.bf-follower-handle:hover { color:var(--bf-accent); }

/* ── Divider between sections ─────────────────────── */
.bf-divider { height:1px; background:var(--bf-card-border); margin:2rem 0; }

@@media (max-width:640px) {
    .bf-hero-inner { gap:1.25rem; }
    .bf-actor-avatar, .bf-actor-avatar-ph { width:80px; height:80px; }
    .bf-actor-avatar-ph { font-size:1.8rem; }
}
</style>

<div class="bf">
    @if (isLoading)
    {
        <div class="bf-loading-wrap">
            <i class="fas fa-circle-notch fa-spin"></i>
            <div class="bf-loading-title">Loading profile…</div>
        </div>
    }
    else if (actor == null)
    {
        <div class="bf-not-found">
            <i class="fas fa-exclamation-triangle"></i>
            <div style="font-weight:700;font-size:.95rem;margin-bottom:.3rem;">Profile not found</div>
            <div style="font-size:.8rem;">This issuer may have been removed or the URL is incorrect.</div>
        </div>
    }
    else
    {
        @* ── Hero banner ──────────────────────────────── *@
        <div class="bf-actor-hero">
            <div class="container">
                <div class="bf-hero-inner">

                    @if (!string.IsNullOrEmpty(actor.AvatarPath))
                    {
                        <img class="bf-actor-avatar" src="@actor.AvatarPath" alt="@actor.FullName" />
                    }
                    else
                    {
                        <div class="bf-actor-avatar-ph"><i class="fas fa-users"></i></div>
                    }

                    <div class="bf-hero-info">
                        <div class="bf-actor-name">@actor.FullName</div>
                        @if (!string.IsNullOrEmpty(actor.Summary))
                        {
                            <div class="bf-actor-summary">@actor.Summary</div>
                        }

                        <div class="bf-hero-stats">
                            <div class="bf-hero-stat">
                                <div class="bf-hero-stat-num">@stats.BadgeCount</div>
                                <div class="bf-hero-stat-lbl">Badges</div>
                            </div>
                            <div class="bf-hero-stat">
                                <div class="bf-hero-stat-num">@stats.IssuedCount</div>
                                <div class="bf-hero-stat-lbl">Issued</div>
                            </div>
                            <div class="bf-hero-stat">
                                <div class="bf-hero-stat-num">@stats.MembersCount</div>
                                <div class="bf-hero-stat-lbl">Awardees</div>
                            </div>
                            @if (actor.ShowFollowers)
                            {
                                <div class="bf-hero-stat">
                                    <div class="bf-hero-stat-num">@followers.Count</div>
                                    <div class="bf-hero-stat-lbl">Followers</div>
                                </div>
                            }
                        </div>

                        <div class="bf-social-links">
                            @if (!string.IsNullOrEmpty(actor.InformationUri))
                            {
                                <a href="@actor.InformationUri" target="_blank" class="bf-social-btn" title="Website">
                                    <i class="fas fa-globe"></i>
                                </a>
                            }
                            @if (actor.Socials != null)
                            {
                                @foreach (var social in actor.Socials.Where(s => !string.IsNullOrWhiteSpace(s.Type) && !string.IsNullOrWhiteSpace(s.Uri)))
                                {
                                    <a href="@GetSocialUrl(social)" target="_blank" class="bf-social-btn" title="@GetSocialTitle(social.Type)">
                                        <i class="@GetSocialIcon(social.Type)"></i>
                                    </a>
                                }
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>

        @* ── Body ─────────────────────────────────────── *@
        <div class="bf-body">
            <div class="container">

                @* Featured badges *@
                <div class="bf-section-hd">
                    <div class="bf-section-title">
                        Featured Badges <span>(@featuredBadges.Count)</span>
                    </div>
                    <a href="/view/actor/@Domain/@Username" class="bf-outline-btn">
                        <i class="fas fa-certificate"></i> All Badges
                    </a>
                </div>

                <div class="bf-badge-grid">
                    @foreach (var badge in featuredBadges)
                    {
                        <div class="bf-badge-card">
                            <div class="bf-badge-img-zone">
                                @if (!string.IsNullOrEmpty(badge.Image))
                                {
                                    <img src="@badge.Image" alt="@badge.ImageAltText" class="bf-badge-img" />
                                }
                                else
                                {
                                    <i class="fas fa-certificate bf-badge-img-ph"></i>
                                }
                            </div>
                            <div class="bf-badge-body">
                                <div class="bf-badge-title">@badge.Title</div>
                                <div class="bf-badge-desc">@badge.Description</div>
                                <div class="bf-badge-footer">
                                    <span class="bf-type-pill">@badge.BadgeType</span>
                                    <a href="/view/badge/@badge.Id/grants" class="bf-recipients-btn">
                                        <i class="fas fa-users"></i>
                                        @(badgeStats.ContainsKey(badge.Id) ? badgeStats[badge.Id].IssuedCount.ToString() : "0") Recipients
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @* Followers *@
                @if (actor.ShowFollowers && followers.Any())
                {
                    <div class="bf-divider"></div>
                    <div class="bf-section-hd">
                        <div class="bf-section-title">
                            Followers <span>(@followers.Count)</span>
                        </div>
                    </div>
                    <div class="bf-followers-grid">
                        @foreach (var follower in followers)
                        {
                            var username = follower.FollowerUri.TrimEnd('/').Split('/').LastOrDefault();
                            var displayName = string.IsNullOrEmpty(follower.DisplayName) ? username : follower.DisplayName;
                            var image = string.IsNullOrEmpty(follower.AvatarUri) ? null : follower.AvatarUri;
                            var initials = string.Join("", (displayName ?? "?").Split(' ', StringSplitOptions.RemoveEmptyEntries).Take(2).Select(w => w[0])).ToUpper();

                            // Deterministic hue from display name for the avatar background
                            var hue = Math.Abs(string.IsNullOrEmpty(displayName) ? 0 : displayName.Aggregate(0, (h, c) => h * 31 + c)) % 360;
                            var avatarBg = $"hsl({hue},55%,38%)";

                            <div class="bf-follower-card">
                                @if (!string.IsNullOrEmpty(image))
                                {
                                    <img class="bf-follower-avatar" src="@image" alt="@displayName" />
                                }
                                else
                                {
                                    <div class="bf-follower-avatar-ph" style="background:@avatarBg">@initials</div>
                                }
                                <div>
                                    <div class="bf-follower-name">@displayName</div>
                                    <a href="@follower.FollowerUri" class="bf-follower-handle">
                                        @@@(username)@@@(follower.Domain)
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }

            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? Domain { get; set; }
    [Parameter] public string? Username { get; set; }

    private Actor? actor;
    private List<Follower> followers = new();

    private ActorStats stats = new();

    private List<Badge> featuredBadges = new();
    private bool isLoading = true;

    private Dictionary<long, BadgeStats> badgeStats = new();


    protected override async Task OnInitializedAsync()
    {
        var acceptHeader = HttpContextAccessor.HttpContext?.Request.Headers["Accept"].ToString();

        if (string.IsNullOrEmpty(Domain))
        {
            Domain = HttpContextAccessor.HttpContext?.Request.Host.Host;
        }

        if (BadgeFed.Core.ActivityPubHelper.IsActivityPubRequest(acceptHeader))
        {
            NavManager.NavigateTo($"/actors/{Domain}/{Username}");
        }

        LoadData();
    }

    private void LoadData()
    {
        actor = DbService.GetActorByFilter($"Username = \"{Username}\" AND Domain = \"{Domain}\"");
        
        if (actor != null)
        {
            stats = DbService.GetIssuerStats(actor);
            if (actor.ShowFollowers)
            {
                followers = DbService.GetFollowersByActorId(actor.Id).ToList();
            }

            var allBadges = DbService.GetBadgesByIssuerId(actor.Id).ToList();

             foreach (var badge in allBadges)
            {
                var stats = DbService.GetBadgeStats(badge.Id);
                badgeStats[badge.Id] = stats;
            }
            
            featuredBadges = allBadges.Take(12).ToList();
        }
        
        isLoading = false;
    }

    private string GetThemeCssPath()
    {
        if (actor?.Theme == null) return string.Empty;
        
        var themePath = CustomAssetPathService.GetThemeUrl(actor.Theme);
        var physicalPath = CustomAssetPathService.GetCustomAssetPath("css", "themes", $"{actor.Theme}.css");
        
        if (File.Exists(physicalPath))
        {
            return themePath;
        }
        
        return string.Empty;
    }

    private string GetSocialIcon(string type)
    {
        return type.ToLower() switch
        {
            "linkedin" => "fab fa-linkedin",
            "mastodon" => "fab fa-mastodon",
            "loops" => "fas fa-video", // No specific icon for Loops, using video
            "youtube" => "fab fa-youtube",
            "peertube" => "fas fa-video", // No specific icon for PeerTube, using video
            "email" => "fas fa-envelope",
            "instagram" => "fab fa-instagram",
            "pixelfed" => "fas fa-camera", // No specific icon for Pixelfed, using camera
            "threads" => "fab fa-threads",
            "github" => "fab fa-github",
            "bluesky" => "fas fa-cloud", // No specific icon for Bluesky, using cloud
            "discord" => "fab fa-discord",
            _ => "fas fa-link"
        };
    }

    private string GetSocialTitle(string type)
    {
        return type.ToLower() switch
        {
            "linkedin" => "LinkedIn",
            "mastodon" => "Mastodon",
            "loops" => "Loops",
            "youtube" => "YouTube",
            "peertube" => "PeerTube",
            "email" => "Email",
            "instagram" => "Instagram",
            "pixelfed" => "Pixelfed",
            "threads" => "Threads",
            "github" => "GitHub",
            "bluesky" => "Bluesky",
            "discord" => "Discord",
            _ => "Social Link"
        };
    }

    private string GetSocialUrl(SocialUri social)
    {
        // Handle email specially
        if (social.Type.ToLower() == "email" && !social.Uri.StartsWith("mailto:"))
        {
            return $"mailto:{social.Uri}";
        }
        
        // For all other types, return the URI as-is
        return social.Uri;
    }
}