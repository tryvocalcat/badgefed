@page "/view/badge/{badgeId}/grants"

@using BadgeFed.Services
@inject IHttpContextAccessor HttpContextAccessor
@inject NavigationManager NavManager
@inject LocalScopedDb DbService
@inject IWebHostEnvironment Environment
@inject ICustomAssetPathService CustomAssetPathService

@if (!string.IsNullOrEmpty(GetThemeCssPath()))
{
    <link rel="stylesheet" href="@GetThemeCssPath()" />
}

<style>
/* ═══════════════════════════════════════════════════
   View Badge Grants — BadgeFed Design System
   Token-driven: themes override --bf-* variables
   ═══════════════════════════════════════════════════ */

.bf {
    /* ── Design tokens (defaults; overridden by theme files) ── */
    --bf-accent:       #6366f1;
    --bf-accent-alt:   #7c3aed;
    --bf-highlight:    #06b6d4;
    --bf-page-bg:      #fff;
    --bf-page-fg:      #0f172a;
    --bf-card-bg:      #fff;
    --bf-card-border:  #e2e8f0;
    --bf-muted:        #64748b;
    --bf-subtle:       #94a3b8;

    background: var(--bf-page-bg);
    color: var(--bf-page-fg);
    font-family:'Inter',system-ui,-apple-system,sans-serif;
}

/* ── Loading / Error ──────────────────────────────── */
.bf-loading-wrap { text-align:center; padding:5rem 1rem; color:var(--bf-subtle); }
.bf-loading-wrap i { font-size:1.6rem; display:block; margin-bottom:.7rem; color:var(--bf-accent); opacity:.4; }
.bf-loading-title { font-size:.95rem; font-weight:600; color:var(--bf-muted); margin-bottom:.25rem; }
.bf-loading-sub   { font-size:.8rem; }
.bf-not-found {
    margin:3rem auto; max-width:480px; text-align:center; padding:3rem 2rem;
    border:1px dashed #fcd34d; border-radius:18px; color:#92400e; background:#fffbeb;
}
.bf-not-found i { font-size:1.8rem; color:#f59e0b; display:block; margin-bottom:.75rem; }

/* ── Page header ──────────────────────────────────── */
.bf-page-header { padding:2.5rem 0 0; background:var(--bf-page-bg); }
.bf-page-lbl {
    display:inline-block; font-size:.68rem; font-weight:700;
    letter-spacing:.1em; text-transform:uppercase; color:var(--bf-accent); margin-bottom:.5rem;
}
.bf-page-title {
    font-size:clamp(1.6rem,3vw,2.2rem); font-weight:900;
    letter-spacing:-.03em; line-height:1.15; color:var(--bf-page-fg); margin-bottom:.35rem;
}
.bf-grad {
    background:linear-gradient(95deg, var(--bf-accent) 0%, var(--bf-highlight) 100%);
    -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;
}

/* ── Badge hero card ──────────────────────────────── */
.bf-badge-card {
    background:var(--bf-card-bg); border:1px solid var(--bf-card-border); border-radius:20px;
    padding:1.75rem; margin:1.75rem 0;
    display:flex; gap:1.5rem; align-items:flex-start; flex-wrap:wrap;
    box-shadow:0 2px 16px color-mix(in srgb, var(--bf-accent) 6%, transparent);
}
.bf-badge-img-wrap {
    flex-shrink:0; width:96px; height:96px; border-radius:16px;
    background:color-mix(in srgb, var(--bf-accent) 6%, var(--bf-card-bg));
    border:1px solid var(--bf-card-border);
    display:flex; align-items:center; justify-content:center; overflow:hidden;
}
.bf-badge-img { width:100%; height:100%; object-fit:contain; border-radius:14px; }
.bf-badge-img-ph { font-size:2rem; color:var(--bf-accent); opacity:.6; }

.bf-badge-info { flex:1; min-width:0; }
.bf-badge-title { font-size:1.25rem; font-weight:800; color:var(--bf-page-fg); margin-bottom:.3rem; line-height:1.2; }
.bf-badge-desc  { font-size:.83rem; color:var(--bf-muted); line-height:1.6; margin-bottom:.75rem; }
.bf-badge-tags  { display:flex; flex-wrap:wrap; gap:.35rem; }
.bf-tag {
    display:inline-flex; align-items:center; gap:.25rem;
    border-radius:999px; padding:.2rem .65rem;
    font-size:.67rem; font-weight:600; letter-spacing:.02em;
}
.bf-tag-type {
    background:color-mix(in srgb, var(--bf-accent) 10%, transparent);
    color:var(--bf-accent);
    border:1px solid color-mix(in srgb, var(--bf-accent) 20%, transparent);
}
.bf-tag-hash {
    background:color-mix(in srgb, var(--bf-page-fg) 5%, var(--bf-card-bg));
    color:var(--bf-muted); border:1px solid var(--bf-card-border);
}
.bf-learn-btn {
    display:inline-flex; align-items:center; gap:.35rem; margin-bottom:.75rem;
    background:color-mix(in srgb, var(--bf-highlight) 10%, transparent);
    border:1px solid color-mix(in srgb, var(--bf-highlight) 25%, transparent);
    color:color-mix(in srgb, var(--bf-highlight) 80%, var(--bf-page-fg));
    border-radius:10px; padding:.35rem .85rem;
    font-size:.75rem; font-weight:600; text-decoration:none;
    transition:background .15s;
}
.bf-learn-btn:hover { background:color-mix(in srgb, var(--bf-highlight) 20%, transparent); }

.bf-issuer-col {
    flex-shrink:0; display:flex; flex-direction:column; align-items:center;
    text-align:center; gap:.4rem; min-width:110px;
}
.bf-issuer-lbl { font-size:.63rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; color:var(--bf-subtle); }
.bf-issuer-avatar {
    width:48px; height:48px; border-radius:50%; object-fit:cover;
    border:2px solid var(--bf-card-border);
}
.bf-issuer-avatar-ph {
    width:48px; height:48px; border-radius:50%;
    background:linear-gradient(135deg, var(--bf-accent), var(--bf-accent-alt));
    display:flex; align-items:center; justify-content:center;
    color:#fff; font-size:1.1rem; font-weight:700;
}
.bf-issuer-name { font-size:.78rem; font-weight:700; color:var(--bf-page-fg); }
.bf-issuer-btn {
    display:inline-flex; align-items:center; gap:.3rem;
    background:color-mix(in srgb, var(--bf-accent) 7%, transparent);
    border:1px solid color-mix(in srgb, var(--bf-accent) 20%, transparent);
    color:var(--bf-accent); border-radius:8px; padding:.28rem .7rem;
    font-size:.7rem; font-weight:600; text-decoration:none;
    transition:background .15s; white-space:nowrap;
}
.bf-issuer-btn:hover { background:color-mix(in srgb, var(--bf-accent) 14%, transparent); }

/* ── Stats row ────────────────────────────────────── */
.bf-stats-row {
    display:flex; gap:0; margin:0 0 2rem;
    border:1px solid var(--bf-card-border); border-radius:16px; overflow:hidden;
    background:var(--bf-card-bg);
}
.bf-stat {
    flex:1; padding:1.1rem 1.5rem; text-align:center;
    border-right:1px solid var(--bf-card-border);
}
.bf-stat:last-child { border-right:none; }
.bf-stat-num { font-size:1.6rem; font-weight:900; color:var(--bf-page-fg); letter-spacing:-.04em; line-height:1; margin-bottom:.25rem; }
.bf-stat-num span { background:linear-gradient(95deg, var(--bf-accent), var(--bf-highlight)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; }
.bf-stat-lbl { font-size:.7rem; color:var(--bf-subtle); font-weight:500; text-transform:uppercase; letter-spacing:.06em; }

/* ── Section heading ──────────────────────────────── */
.bf-section-title { font-size:1rem; font-weight:800; color:var(--bf-page-fg); margin-bottom:1.25rem; }
.bf-section-title span { color:var(--bf-accent); }

/* ── Recipient grid ───────────────────────────────── */
.bf-recipients-grid {
    display:grid;
    grid-template-columns:repeat(auto-fill, minmax(260px, 1fr));
    gap:1rem;
}
.bf-recipient-card {
    background:var(--bf-card-bg); border:1px solid var(--bf-card-border); border-radius:16px;
    padding:1.1rem 1.2rem; display:flex; flex-direction:column; gap:.75rem;
    transition:border-color .2s, box-shadow .2s, transform .2s;
}
.bf-recipient-card:hover {
    border-color:color-mix(in srgb, var(--bf-accent) 50%, var(--bf-card-border));
    box-shadow:0 4px 20px color-mix(in srgb, var(--bf-accent) 9%, transparent);
    transform:translateY(-1px);
}
.bf-recipient-top { display:flex; align-items:center; gap:.75rem; }
.bf-initials {
    flex-shrink:0; width:40px; height:40px; border-radius:12px;
    background:linear-gradient(135deg, var(--bf-accent), var(--bf-accent-alt));
    display:flex; align-items:center; justify-content:center;
    color:#fff; font-size:.75rem; font-weight:700; letter-spacing:.02em;
}
.bf-recipient-name { font-size:.88rem; font-weight:700; color:var(--bf-page-fg); line-height:1.3; }
.bf-recipient-date { font-size:.72rem; color:var(--bf-subtle); display:flex; align-items:center; gap:.3rem; margin-top:.1rem; }
.bf-recipient-date i { font-size:.65rem; }
.bf-recipient-actions { display:flex; gap:.5rem; flex-wrap:wrap; }
.bf-rc-btn {
    display:inline-flex; align-items:center; gap:.3rem;
    border-radius:8px; padding:.3rem .7rem;
    font-size:.72rem; font-weight:600; text-decoration:none;
    transition:background .15s; white-space:nowrap;
}
.bf-rc-btn.primary {
    background:color-mix(in srgb, var(--bf-accent) 8%, transparent);
    border:1px solid color-mix(in srgb, var(--bf-accent) 20%, transparent);
    color:var(--bf-accent);
}
.bf-rc-btn.primary:hover { background:color-mix(in srgb, var(--bf-accent) 15%, transparent); }
.bf-rc-btn.secondary {
    background:color-mix(in srgb, var(--bf-page-fg) 5%, var(--bf-card-bg));
    border:1px solid var(--bf-card-border); color:var(--bf-muted);
}
.bf-rc-btn.secondary:hover { background:color-mix(in srgb, var(--bf-page-fg) 8%, var(--bf-card-bg)); }

/* ── Empty state ──────────────────────────────────── */
.bf-empty {
    text-align:center; padding:4rem 2rem; border-radius:18px;
    border:1px dashed var(--bf-card-border); color:var(--bf-subtle);
}
.bf-empty i { font-size:2rem; display:block; margin-bottom:.75rem; color:var(--bf-accent); opacity:.4; }
.bf-empty-title { font-size:1rem; font-weight:700; color:var(--bf-muted); margin-bottom:.3rem; }
.bf-empty-sub   { font-size:.83rem; line-height:1.6; }

/* ── Section padding ──────────────────────────────── */
.bf-s { padding:2rem 0 3rem; }
</style>

<div class="bf">
    @if (isLoading)
    {
        <div class="bf-loading-wrap">
            <i class="fas fa-circle-notch fa-spin"></i>
            <div class="bf-loading-title">Loading badge grants…</div>
            <div class="bf-loading-sub">Please wait</div>
        </div>
    }
    else if (badge == null)
    {
        <div class="bf-not-found">
            <i class="fas fa-exclamation-triangle"></i>
            <div style="font-weight:700;font-size:.95rem;margin-bottom:.3rem;">Badge not found</div>
            <div style="font-size:.8rem;">This badge may have been removed or the URL is incorrect.</div>
        </div>
    }
    else
    {
        <div class="bf-page-header">
            <div class="container">
                <span class="bf-page-lbl">Badge Recipients</span>
                <h1 class="bf-page-title"><span class="bf-grad">@badge.Title</span> Grants</h1>
            </div>
        </div>

        <div class="bf-s">
            <div class="container">

                @* Badge hero card *@
                <div class="bf-badge-card">
                    <div class="bf-badge-img-wrap">
                        @if (!string.IsNullOrEmpty(badge.Image))
                        {
                            <img src="@badge.Image" alt="@badge.ImageAltText" class="bf-badge-img" />
                        }
                        else
                        {
                            <i class="fas fa-certificate bf-badge-img-ph"></i>
                        }
                    </div>

                    <div class="bf-badge-info">
                        <div class="bf-badge-title">@badge.Title</div>
                        <div class="bf-badge-desc">@badge.Description</div>
                        @if (!string.IsNullOrEmpty(badge.InfoUri))
                        {
                            <a href="@badge.InfoUri" target="_blank" class="bf-learn-btn">
                                <i class="fas fa-external-link-alt"></i> Learn more
                            </a>
                        }
                        <div class="bf-badge-tags">
                            <span class="bf-tag bf-tag-type">@badge.BadgeType</span>
                            @if (!string.IsNullOrEmpty(badge.Hashtags))
                            {
                                @foreach (var hashtag in badge.HashtagsList)
                                {
                                    <span class="bf-tag bf-tag-hash">#@hashtag</span>
                                }
                            }
                        </div>
                    </div>

                    <div class="bf-issuer-col">
                        <div class="bf-issuer-lbl">Issued by</div>
                        @if (!string.IsNullOrEmpty(actor?.AvatarPath))
                        {
                            <img src="@actor.AvatarPath" alt="@actor.FullName" class="bf-issuer-avatar" />
                        }
                        else
                        {
                            <div class="bf-issuer-avatar-ph">@(actor?.FullName?.Substring(0,1).ToUpper() ?? "?")</div>
                        }
                        <div class="bf-issuer-name">@actor?.FullName</div>
                        <a href="/view/actor/@actor?.Domain/@actor?.Username" class="bf-issuer-btn">
                            <i class="fas fa-building"></i> View Issuer
                        </a>
                    </div>
                </div>

                @* Stats *@
                <div class="bf-stats-row">
                    <div class="bf-stat">
                        <div class="bf-stat-num"><span>@publicGrants.Count</span></div>
                        <div class="bf-stat-lbl">Public Recipients</div>
                    </div>
                    <div class="bf-stat">
                        <div class="bf-stat-num"><span>@stats.IssuedCount</span></div>
                        <div class="bf-stat-lbl">Total Issued</div>
                    </div>
                </div>

                @* Recipients grid *@
                @if (publicGrants.Any())
                {
                    <div class="bf-section-title">
                        Recipients <span>(@publicGrants.Count)</span>
                    </div>
                    <div class="bf-recipients-grid">
                        @foreach (var grant in publicGrants)
                        {
                            <div class="bf-recipient-card">
                                <div class="bf-recipient-top">
                                    <div class="bf-initials">@GetRecipientInitials(grant.IssuedToName)</div>
                                    <div>
                                        <div class="bf-recipient-name">@grant.IssuedToName</div>
                                        <div class="bf-recipient-date">
                                            <i class="fas fa-calendar"></i>
                                            @grant.IssuedOn.ToString("MMM d, yyyy")
                                        </div>
                                    </div>
                                </div>
                                <div class="bf-recipient-actions">
                                    @if (!string.IsNullOrEmpty(grant.NoteId))
                                    {
                                        <a href="@grant.NoteId" class="bf-rc-btn primary">
                                            <i class="fas fa-eye"></i> View Grant
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(grant.IssuedToSubjectUri))
                                    {
                                        <a href="@grant.IssuedToSubjectUri" class="bf-rc-btn secondary">
                                            <i class="fas fa-user"></i> Profile
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="bf-empty">
                        <i class="fas fa-medal"></i>
                        <div class="bf-empty-title">No public recipients yet</div>
                        <div class="bf-empty-sub">This badge hasn't been publicly granted to anyone yet, or all grants are marked as private.</div>
                    </div>
                }

            </div>
        </div>
    }
</div>

@code {
    [Parameter] public string? BadgeId { get; set; }

    private Badge? badge;
    private Actor? actor;
    private List<BadgeRecord> publicGrants = new();
    
    private bool isLoading = true;

    private BadgeStats stats = new BadgeStats();

    protected override async Task OnInitializedAsync()
    {
        var acceptHeader = HttpContextAccessor.HttpContext?.Request.Headers["Accept"].ToString();

        if (BadgeFed.Core.ActivityPubHelper.IsActivityPubRequest(acceptHeader))
        {
            NavManager.NavigateTo($"/badge/{BadgeId}");
        }

        LoadData();
    }

    private void LoadData()
    {
        if (long.TryParse(BadgeId, out long badgeIdValue))
        {
            badge = DbService.GetBadgeDefinitionById(badgeIdValue);
            
            if (badge != null)
            {
                actor = DbService.GetActorById(badge.IssuedBy);

                 var publicGrantsFilter = new LocalDbService.Filter
                {
                    Where = "BadgeId = @BadgeId AND (Visibility = 'Public' OR Visibility IS NULL) AND AcceptedOn IS NOT NULL AND RevokedAt IS NULL",
                    Parameters = new Dictionary<string, object> { { "@BadgeId", badgeIdValue } }
                };
                publicGrants = DbService.GetBadgeRecords(publicGrantsFilter, true)
                    .OrderByDescending(g => g.AcceptedOn ?? g.IssuedOn)
                    .ToList();
                
                stats = DbService.GetBadgeStats(badge.Id);
            }
        }
        
        isLoading = false;
    }

    private string GetRecipientInitials(string name)
    {
        if (string.IsNullOrEmpty(name)) return "?";
        var words = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (words.Length == 1)
            return words[0].Substring(0, Math.Min(2, words[0].Length)).ToUpper();
        return string.Join("", words.Take(2).Select(w => w[0])).ToUpper();
    }

    private string TruncateUri(string uri)
    {
        if (string.IsNullOrEmpty(uri)) return string.Empty;
        if (uri.Length <= 50) return uri;
        return uri.Substring(0, 47) + "...";
    }

    private string GetThemeCssPath()
    {
        if (actor?.Theme == null) return string.Empty;
        var themePath = CustomAssetPathService.GetThemeUrl(actor.Theme);
        var physicalPath = CustomAssetPathService.GetCustomAssetPath("css", "themes", $"{actor.Theme}.css");
        return File.Exists(physicalPath) ? themePath : string.Empty;
    }
}
