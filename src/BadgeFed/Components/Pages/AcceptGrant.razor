@page "/accept/grant/{id}/{key}"
@using ActivityPubDotNet.Core
@using System.Text.Json
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager NavManager
@using BadgeFed.Core
@inject LocalScopedDb DbService
@inject BadgeProcessor BadgeProcessor
@using BadgeFed.Models
@using Markdig
@inject HttpClient HttpClient
@inject IConfiguration Configuration
@rendermode InteractiveServer

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="has-text-centered">
        <p>@errorMessage</p>
    </div>
}
else if (accepted)
{
    <div class="accept-grant-success">
        <h4>
            <i class="oi oi-check"></i>
            Badge Accepted!
        </h4>
        <p>
            Your badge has been accepted and added to your collection.
            It will be published to the network shortly.
            <strong>Refresh this page in a few moments to see it.</strong>
        </p>
    </div>
} else {
<div class="accept-grant-congrats">
    <h4>
        <i class="oi oi-star"></i>
        Congratulations!
        <a href="/pages/how-to-accept-a-badge.html" target="_blank" title="Need help accepting your badge?" style="margin-left: 8px; font-size: 0.75em; color: #4f46e5; vertical-align: middle;">
            <i class="fas fa-question-circle"></i>
        </a>
    </h4>
    <p>You've earned this @Badge.BadgeType. Accept it to add it to your collection.</p>
</div>
<div class="card accept-grant-card">
    <div class="accept-grant-hero">
        <div class="accept-grant-badge-img">
            <img src="@BadgeRecord.Image" alt="@BadgeRecord.ImageAltText" />
        </div>
        <h3 class="accept-grant-title">@BadgeRecord.Title</h3>
        <p class="accept-grant-issuer">
            <span class="icon is-small"><i class="fas fa-user-shield"></i></span>
            Issued by <a href="@Actor.Uri">@Actor.FullName</a>
        </p>
    </div>
    <div class="card-content">
        <div class="accept-grant-details">
            <div class="accept-grant-detail-item">
                <span class="accept-grant-detail-icon"><i class="fas fa-info-circle"></i></span>
                <div class="accept-grant-detail-body">
                    <span class="accept-grant-detail-label">Description</span>
                    @if (!emailValidated)
                    {
                        <div class="accept-grant-locked">
                            <p class="accept-grant-locked-preview">@(BadgeRecord.Description?.Length > 80 ? BadgeRecord.Description.Substring(0, 80) : BadgeRecord.Description)</p>
                            <div class="accept-grant-locked-overlay">
                                <i class="fas fa-lock"></i>
                            </div>
                        </div>
                    }
                    else
                    {
                        <p class="accept-grant-detail-text">@BadgeRecord.Description</p>
                    }
                </div>
            </div>
            <div class="accept-grant-detail-item">
                <span class="accept-grant-detail-icon"><i class="fas fa-trophy"></i></span>
                <div class="accept-grant-detail-body">
                    <span class="accept-grant-detail-label">Earning Criteria</span>
                    @if (!emailValidated)
                    {
                        <div class="accept-grant-locked">
                            <p class="accept-grant-locked-preview">@(BadgeRecord.EarningCriteria?.Length > 80 ? BadgeRecord.EarningCriteria.Substring(0, 80) : BadgeRecord.EarningCriteria)</p>
                            <div class="accept-grant-locked-overlay">
                                <i class="fas fa-lock"></i>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="accept-grant-detail-text accept-grant-markdown">@((MarkupString)Markdown.ToHtml(BadgeRecord.EarningCriteria ?? ""))</div>
                    }
                </div>
            </div>
            <div class="accept-grant-detail-item">
                <span class="accept-grant-detail-icon"><i class="fas fa-calendar-alt"></i></span>
                <div>
                    <span class="accept-grant-detail-label">Issued On</span>
                    <p class="accept-grant-detail-text">@BadgeRecord.IssuedOn.ToShortDateString()</p>
                </div>
            </div>
        </div>
    </div>
 <div class="card-content">
    <!-- Form Section -->
    <form @onsubmit="HandleValidSubmit" method="post">
    <div class="accept-grant-form-section">
        @if (emailValidated)
        {
            <div class="accept-grant-note">
                <i class="fas fa-info-circle"></i>
                <span>This information will be permanently associated with this badge once accepted. Please ensure all details are correct.</span>
            </div>
        }

        @if (!emailValidated)
        {
            <!-- Email Input -->
            <div class="accept-grant-field">
                <label class="field-label" for="email">Confirm Email Address</label>
                <div class="control">
                    <input type="email" id="email" class="input" @bind="acceptEmail" 
                    required />
                </div>
                <p class="field-hint">
                    Enter the email address this badge was originally sent to.
                </p>
            </div>
            <div class="control">
                <button class="accept-grant-validate-btn" @onclick="ValidateEmail" type="button">Validate</button>
            </div>

            @if (invalidEmail)
            {
                <div class="accept-grant-email-error">
                    <i class="oi oi-warning"></i>
                    <span>
                        The email address doesn't match our records. 
                        Please try the email this badge was sent to, or contact the issuer.
                    </span>
                </div>
            }
        }
        else 
        {
            <!-- Profile URI Input -->
            <div class="accept-grant-field">
                <label class="field-label" for="profileUri">
                    @if (linkMode == "lin")
                    {
                        <span>LinkedIn Profile</span>
                    }
                    else
                    {
                        <span>Profile URL</span>
                    }
                    <span class="tag-required">Required</span>
                    <span class="why-url-link" @onclick="OpenHelpModal" title="Why a URL instead of email?">
                        <i class="fas fa-question-circle"></i>
                        Why not email?
                    </span>
                     <a class="profile-help-toggle" @onclick="ToggleProfileHelp" @onclick:preventDefault>
                            <span class="icon is-small">
                                <i class="fas @(showProfileHelp ? "fa-chevron-up" : "fa-lightbulb")"></i>
                            </span>
                            <span>@(showProfileHelp ? "Got it, thanks" : "Need help choosing?")</span>
                        </a>
                </label>

                  @if (showProfileHelp)
                    {
                        @* Compact type selector pills *@
                        <div class="url-type-pills mt-2 profile-help-panel">
                            <span class="is-size-7 has-text-grey mr-2">I'll use:</span>
                            <button type="button" class='url-pill @(urlPickerSelection == "linkedin" ? "active" : "")' @onclick='() => SelectUrlType("linkedin")'>
                                <i class="fab fa-linkedin"></i> LinkedIn
                            </button>
                            <button type="button" class='url-pill url-pill-wallet @(urlPickerSelection == "fedihub" ? "active" : "")' @onclick='() => SelectUrlType("fedihub")'>
                                <i class="fas fa-wallet"></i> Wallet
                            </button>
                    
                            <button type="button" class='url-pill @(urlPickerSelection == "mastodon" ? "active" : "")' @onclick='() => SelectUrlType("mastodon")'>
                                <i class="fab fa-mastodon"></i> Mastodon
                            </button>
                            
                            <button type="button" class='url-pill @(urlPickerSelection == "website" ? "active" : "")' @onclick='() => SelectUrlType("website")'>
                                <i class="fas fa-globe"></i> Website
                            </button>
                            <button type="button" class='url-pill @(urlPickerSelection == "github" ? "active" : "")' @onclick='() => SelectUrlType("github")'>
                                <i class="fab fa-github"></i> GitHub
                            </button>
                            <button type="button" class='url-pill @(urlPickerSelection == "other" ? "active" : "")' @onclick='() => SelectUrlType("other")'>
                                <i class="fas fa-link"></i> Other
                            </button>
                        </div>

                        @* One-line hint *@
                        @if (!string.IsNullOrEmpty(urlPickerHint))
                        {
                            <p class="help mt-1" style="color: #555;">@((MarkupString)urlPickerHint)</p>
                        }
                    }

                @if (linkMode == "lin")
                {
                    <div class="field has-addons">
                        <p class="control">
                            <a class="button is-static" style="border-radius: 10px 0 0 10px; border: 1.5px solid #dde0e6; border-right: none; font-size: 0.85rem; color: #8b8f9a;">
                                https://linkedin.com/in/
                            </a>
                        </p>
                        <p class="control is-expanded">
                            <input type="text" id="profileUri" 
                                   class="input @ProfileInputCssClass" 
                                   style="border-radius: 0 10px 10px 0;"
                                   value="@linkedInUsername" 
                                   @oninput="OnLinkedInUsernameInput"
                                   placeholder="your-username" />
                        </p>
                    </div>
                    @if (profileUrlState == UrlValidationState.Valid || profileUrlState == UrlValidationState.ValidAP)
                    {
                        <p class="field-hint" style="color: #3d8c5c;">
                            <i class="fas fa-check-circle"></i>
                            @ValidationProfileMessage
                        </p>
                    }
                    else
                    {
                        <p class="field-hint">
                            Enter just your LinkedIn username — the part after <strong>linkedin.com/in/</strong>.
                        </p>
                    }
                }
                else
                {
                    <div class="control has-icons-right">
                        <input type="url" id="profileUri" 
                               class="input @ProfileInputCssClass" 
                               value="@Model.ProfileUri" 
                               @oninput="OnProfileUrlInput"
                               placeholder="@urlPlaceholder" />
                        @if (profileUrlState == UrlValidationState.Checking)
                        {
                            <span class="icon is-small is-right" style="pointer-events:none">
                                <i class="fas fa-spinner fa-spin"></i>
                            </span>
                        }
                        else if (profileUrlState == UrlValidationState.Valid || profileUrlState == UrlValidationState.ValidAP)
                        {
                            <span class="icon is-small is-right has-text-success" style="pointer-events:none">
                                <i class="fas fa-check-circle"></i>
                            </span>
                        }
                        else if (profileUrlState == UrlValidationState.Error)
                        {
                            <span class="icon is-small is-right has-text-danger" style="pointer-events:none">
                                <i class="fas fa-exclamation-triangle"></i>
                            </span>
                        }
                    </div>

                    @* Inline validation message *@
                    @if (profileUrlState == UrlValidationState.Error)
                    {
                        <p class="help is-danger">@ValidationProfileMessage</p>
                    }
                    else if (profileUrlState == UrlValidationState.Valid || profileUrlState == UrlValidationState.ValidAP)
                    {
                        <p class="help is-success">@ValidationProfileMessage</p>
                    }
                    else if (profileUrlState == UrlValidationState.Checking)
                    {
                        <p class="help has-text-grey">Checking…</p>
                    }

                  

                    @if (showWalletReplacePrompt)
                    {
                        <div class="notification is-warning is-light mt-3" style="border-radius: 10px;">
                            <p class="is-size-7 mb-2">
                                <i class="fas fa-exclamation-triangle"></i>
                                <strong>Your wallet returned a profile URL</strong> that differs from the one below.
                                Make sure <strong>@Model.ProfileUri</strong> is added as a verified URI in your wallet. If it isn't, you can use your wallet URL instead.
                            </p>
                            <p class="is-size-7 mb-2">Replace with: <code>@walletReturnUrl</code></p>
                            <div class="buttons are-small">
                                <button type="button" class="button is-warning is-small" @onclick="AcceptWalletUrl">
                                    <span class="icon is-small"><i class="fas fa-exchange-alt"></i></span>
                                    <span>Use wallet URL</span>
                                </button>
                                <button type="button" class="button is-light is-small" @onclick="DismissWalletPrompt">
                                    <span class="icon is-small"><i class="fas fa-times"></i></span>
                                    <span>Keep current</span>
                                </button>
                            </div>
                        </div>
                    }

                    @if (hasCta)
                    {
                        <div class="profile-cta mt-3">
                            <div class="profile-cta-content">
                                <span class="profile-cta-icon">
                                    @switch (ctaType)
                                    {
                                        case "fedihub":
                                            <i class="fas fa-wallet"></i>
                                            break;
                                        case "mastodon":
                                            <i class="fab fa-mastodon"></i>
                                            break;
                                        default:
                                            <i class="fas fa-globe"></i>
                                            break;
                                    }
                                </span>
                                <span class="is-size-7">
                                    @switch (ctaType)
                                    {
                                        case "fedihub":
                                            <text>No profile yet? <strong>Get a free Badge Wallet</strong></text>
                                            break;
                                        case "mastodon":
                                            <text>No profile yet? <strong>Create a free Mastodon account</strong></text>
                                            break;
                                        default:
                                            <text>No profile yet? <strong>Create a free Fediverse profile</strong></text>
                                            break;
                                    }
                                </span>
                                <a href="@CtaHelper.BuildCtaUrl(ctaUrl, NavManager.Uri)" target="_blank" rel="noopener" class="profile-cta-btn">
                                    Get Started <i class="fas fa-external-link-alt"></i>
                                </a>
                            </div>
                        </div>
                    }
                }

            </div>

            <!-- Full Name Input -->
            <div class="accept-grant-field">
                <label class="field-label" for="fullName">Full Name</label>
                <div class="control">
                    <input type="text" id="fullName" class="input" @bind="Model.Name" required placeholder="Enter your full name"/>
                </div>
            </div>
           
            <!-- Visibility Select -->
            <div class="accept-grant-field">
                <label class="field-label" for="visibility">Visibility</label>
                <div class="control">
                    <div class="select">
                        <select id="visibility" @bind="visibility">
                            <option value="Public">Public</option>
                            <option value="Unlisted">Unlisted</option>
                        </select>
                    </div>
                </div>
                <p class="field-hint">
                    Unlisted badges are not searchable, but anyone with the direct link can view them.
                </p>
            </div>

            <!-- Submit Button -->
            <div class="accept-grant-field">
                <p class="accept-grant-certify">
                    By accepting this badge I certify I completed the earning criteria.
                </p>
                <button type="submit" class="accept-grant-submit">Accept Badge</button>
            </div>
        }
    </div>
    </form></div>
</div>

}

@* Profile URL Help Modal *@
<ProfileUrlHelpModal IsOpen="@showHelpModal" OnClose="CloseHelpModal" CtaType="@ctaType" CtaUrl="@ctaUrl" />

@code 
{
    [Parameter] public string Id { get; set; }
    [Parameter] public string Key { get; set; }

    public Recipient? Model = new();

    public BadgeRecord BadgeRecord;

    private string visibility = "Public";

    public Badge Badge;

    public Actor Actor;

    public bool accepted = false;

    private string acceptEmail;

    public string ValidationProfileMessage { get; set; } = string.Empty;

    private enum UrlValidationState { Empty, Typing, Error, Checking, Valid, ValidAP }
    private UrlValidationState profileUrlState = UrlValidationState.Empty;

    private System.Threading.Timer? _debounceTimer;
    private string _lastValidatedUrl = string.Empty;

    private string ProfileInputCssClass => profileUrlState switch
    {
        UrlValidationState.Error => "is-danger",
        UrlValidationState.Valid or UrlValidationState.ValidAP => "is-success",
        UrlValidationState.Checking => "",
        _ => ""
    };

    private bool emailValidated = false;

    private bool invalidEmail = false;

    private string errorMessage = string.Empty;

    private string linkMode = string.Empty;

    private string linkedInUsername = string.Empty;

    private bool showHelpModal = false;

    private bool showProfileHelp = false;

    private string urlPickerSelection = string.Empty;
    private string urlPlaceholder = "https://your-profile-url";
    private string urlPickerHint = string.Empty;

    private string ctaType = string.Empty;
    private string ctaUrl = string.Empty;
    private bool hasCta => !string.IsNullOrEmpty(ctaType) && !string.IsNullOrEmpty(ctaUrl);

    private string walletReturnUrl = string.Empty;
    private bool showWalletReplacePrompt = false;

    private void OpenHelpModal() => showHelpModal = true;
    private void CloseHelpModal() => showHelpModal = false;
    private void ToggleProfileHelp() => showProfileHelp = !showProfileHelp;

    private void AcceptWalletUrl()
    {
        Model.ProfileUri = walletReturnUrl;
        linkMode = "";
        showWalletReplacePrompt = false;
        RunInstantValidation(walletReturnUrl);
        ScheduleDeepValidation(walletReturnUrl);
        walletReturnUrl = string.Empty;
    }

    private void DismissWalletPrompt()
    {
        showWalletReplacePrompt = false;
        walletReturnUrl = string.Empty;
    }

    private void OnProfileUrlInput(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";
        Model.ProfileUri = value;
        RunInstantValidation(value);
        ScheduleDeepValidation(value);
    }

    private void OnLinkedInUsernameInput(ChangeEventArgs e)
    {
        linkedInUsername = e.Value?.ToString() ?? "";
        var fullUrl = string.IsNullOrWhiteSpace(linkedInUsername)
            ? ""
            : $"https://linkedin.com/in/{linkedInUsername.Trim().Trim('/')}";
        Model.ProfileUri = fullUrl;

        if (string.IsNullOrWhiteSpace(linkedInUsername))
        {
            profileUrlState = UrlValidationState.Empty;
            ValidationProfileMessage = "";
        }
        else
        {
            profileUrlState = UrlValidationState.Typing;
            ValidationProfileMessage = "";
            ScheduleDeepValidation(fullUrl);
        }
    }

    private void RunInstantValidation(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            profileUrlState = UrlValidationState.Empty;
            ValidationProfileMessage = "";
            return;
        }

        // Must start with https://
        if (!value.StartsWith("https://"))
        {
            // Allow partial typing of "https://" without screaming
            if ("https://".StartsWith(value, StringComparison.OrdinalIgnoreCase))
            {
                profileUrlState = UrlValidationState.Typing;
                ValidationProfileMessage = "";
            }
            else
            {
                profileUrlState = UrlValidationState.Error;
                ValidationProfileMessage = "URL must start with https://";
            }
            return;
        }

        // Has protocol but not enough content
        if (value.Length <= "https://".Length)
        {
            profileUrlState = UrlValidationState.Typing;
            ValidationProfileMessage = "";
            return;
        }

        // Check valid URL syntax
        if (!Uri.TryCreate(value, UriKind.Absolute, out var uri) || string.IsNullOrEmpty(uri.Host) || !uri.Host.Contains('.'))
        {
            profileUrlState = UrlValidationState.Typing;
            ValidationProfileMessage = "";
            return;
        }

        // Locally valid — show green immediately, deep check will follow
        profileUrlState = UrlValidationState.Valid;
        ValidationProfileMessage = "\u2713 Valid URL";
    }

    private void ScheduleDeepValidation(string url)
    {
        _debounceTimer?.Dispose();
        _debounceTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await DeepValidateProfileUrl(url);
                StateHasChanged();
            });
        }, null, 800, Timeout.Infinite);
    }

    private async Task DeepValidateProfileUrl(string url)
    {
        if (string.IsNullOrWhiteSpace(url) || !url.StartsWith("https://") || !Uri.TryCreate(url, UriKind.Absolute, out var uri)
            || string.IsNullOrEmpty(uri.Host) || !uri.Host.Contains('.'))
            return;

        if (url == _lastValidatedUrl)
            return;
        _lastValidatedUrl = url;

        profileUrlState = UrlValidationState.Checking;
        ValidationProfileMessage = "";
        StateHasChanged();

        try
        {
            var actorHelper = new ActorHelper(Actor.PrivateKeyPem, Actor.KeyId);
            var fediverseInfo = await actorHelper.FetchActorInformationAsync(url);

            // Check the URL hasn't changed while we were fetching
            if (Model.ProfileUri != url)
                return;

            if (fediverseInfo != null)
            {
                Model.IsActivityPubActor = true;
                profileUrlState = UrlValidationState.ValidAP;
                ValidationProfileMessage = "\u2713 Valid URL \u2713 ActivityPub endpoint";

                if (!string.IsNullOrEmpty(fediverseInfo.Name))
                {
                    Model.Name = fediverseInfo.Name;
                    ValidationProfileMessage += " \u2713 Name autofilled";
                }
                else if (!string.IsNullOrEmpty(fediverseInfo.PreferredUsername))
                {
                    Model.Name = fediverseInfo.PreferredUsername;
                    ValidationProfileMessage += " \u2713 Name autofilled";
                }
            }
            else
            {
                Model.IsActivityPubActor = false;
                profileUrlState = UrlValidationState.Valid;
                ValidationProfileMessage = "\u2713 Valid URL";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error validating profile URL: {ex.Message}");
            if (Model.ProfileUri == url)
            {
                profileUrlState = UrlValidationState.Valid;
                ValidationProfileMessage = "\u2713 Valid URL";
            }
        }
    }

    private void SelectUrlType(string type)
    {
        urlPickerSelection = type;
        // Update placeholder and hint
        urlPlaceholder = type switch
        {
            "linkedin" => "https://linkedin.com/in/your-username",
            "mastodon" => "https://mastodon.social/@you",
            "github" => "https://github.com/your-username",
            "fedihub" => ctaUrl + "/@you",
            "website" => "https://yoursite.com",
            _ => "https://your-profile-url"
        };
        urlPickerHint = type switch
        {
            "linkedin" => "e.g. <code>https://linkedin.com/in/janedoe</code>",
            "mastodon" => "e.g. <code>https://mastodon.social/@janedoe</code> — unlocks badge sharing &amp; verification",
            "github" => "e.g. <code>https://github.com/janedoe</code>",
            "fedihub" => $"e.g. <code>{ctaUrl}/@janedoe</code> — your badge wallet",
            "website" => "e.g. <code>https://janedoe.com</code>",
            _ => hasCta
                ? $"Any public URL works, but we recommend a <a href=\"{CtaHelper.BuildCtaUrl(ctaUrl, NavManager.Uri)}\" target=\"_blank\"><strong>free Badge Wallet</strong></a> for the best experience."
                : "Any public URL: about.me, Linktree, Codeberg, Instagram, etc."
        };
       
        if (type == "linkedin")
        {
            linkMode = "lin";
        }
        else
        {
            linkMode = "";
        }
    }

    public async Task ValidateEmail()
    {
        emailValidated = acceptEmail == BadgeRecord.IssuedToEmail;
        invalidEmail = !emailValidated;
    }

    public async Task HandleValidSubmit()
    {
        DbService.UpsertRecipient(Model);

        var issuedTo = Model.ProfileUri; //Model.IsActivityPubActor ? : $"https://{Actor.Domain}/recipients/{Actor.Domain}/{Model.Id}";

        if (string.IsNullOrEmpty(issuedTo))
        {
            errorMessage = "Profile URI is required (e.g. https://linkedin.com/in/username or https://mastodon.social/@username).";
            return;
        }

        BadgeRecord.IssuedToName = Model.Name;
        BadgeRecord.IssuedToSubjectUri = issuedTo;
        BadgeRecord.IssuedToEmail = string.Empty;
        BadgeRecord.Visibility = visibility;

        DbService.AcceptBadgeRecord(BadgeRecord);

        accepted = true;

        try {
            BadgeRecord = await BadgeProcessor.SignAndGenerateBadge(BadgeRecord.Id);

            if (!string.IsNullOrEmpty(BadgeRecord?.NoteId))
            {
                NavManager.NavigateTo(BadgeRecord.NoteId);

                return;
            }
        } catch (Exception ex) {
            Console.WriteLine($"WARNING - Error processing badge: {ex.Message}");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        // Load ProfileCTA from database
        var instanceDesc = DbService.GetInstanceDescription();
        ctaType = (instanceDesc.ProfileCTAType ?? "").ToLowerInvariant();
        ctaUrl = instanceDesc.ProfileCTAUrl ?? "";

        var id = long.Parse(Id);
        var record = DbService.GetBadgeToAccept(id);

        if (record == null)
        {
            errorMessage = "Badge record not found or was already accepted.";
            return;
        }

        if (!string.IsNullOrEmpty(record?.AcceptKey) && record?.AcceptKey != Key)
        {
            errorMessage = "Badge record not found or invalid verification key. Please check that you've used the complete link from your email. If you continue to have trouble, contact the badge issuer.";
            return;
        }

        if (string.IsNullOrEmpty(record?.AcceptKey) && string.IsNullOrEmpty(record?.NoteId))
        {
            errorMessage = "Your badge is on an adventure! It's currently being signed, federated, and prepared for your collection. Please check back in a few moments while our digital elves do their magic!";
            return;
        }

        if (!string.IsNullOrEmpty(record?.NoteId))
        {
            NavManager.NavigateTo(record.NoteId);

            return;
        }

        Model = DbService.GetRecipientByIssuedTo(record);
        
        Badge = DbService.GetBadgeDefinitionById(record.Badge.Id);

        Actor = DbService.GetActorById(Badge.IssuedBy);

        BadgeRecord = record;

        emailValidated = string.IsNullOrEmpty(BadgeRecord.IssuedToEmail);

        // Parse query parameters
        var uri = new Uri(NavManager.Uri);
        var queryParams = QueryHelpers.ParseQuery(uri.Query);

        if (queryParams.TryGetValue("l", out var lValue))
        {
            linkMode = lValue.ToString().ToLowerInvariant();
        }

        // Handle wallet return with profileUrl
        if (queryParams.TryGetValue("profileUrl", out var returnedProfileUrl))
        {
            var walletUrl = returnedProfileUrl.ToString().Trim();
            if (!string.IsNullOrEmpty(walletUrl) && walletUrl.StartsWith("https://"))
            {
                if (!string.IsNullOrEmpty(Model.ProfileUri) && Model.ProfileUri != walletUrl)
                {
                    // Profile already set and different — ask user
                    walletReturnUrl = walletUrl;
                    showWalletReplacePrompt = true;
                }
                else
                {
                    // No profile yet or same URL — just set it
                    Model.ProfileUri = walletUrl;
                    linkMode = ""; // ensure full-URL mode
                    RunInstantValidation(walletUrl);
                    ScheduleDeepValidation(walletUrl);
                }
            }
        }

        // Auto-detect LinkedIn from existing IssuedToSubjectUri
        if (string.IsNullOrEmpty(linkMode) 
            && !string.IsNullOrEmpty(record.IssuedToSubjectUri) 
            && record.IssuedToSubjectUri.Contains("linkedin.com", StringComparison.OrdinalIgnoreCase))
        {
            linkMode = "lin";

            // Pre-fill the username from the URL
            var match = System.Text.RegularExpressions.Regex.Match(
                record.IssuedToSubjectUri, @"linkedin\.com/in/([^/?#]+)", 
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            if (match.Success)
            {
                linkedInUsername = match.Groups[1].Value;
            }
        }
    }
}