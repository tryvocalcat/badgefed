@page "/admin/grants"

@using System.IO
@using Microsoft.AspNetCore.Hosting
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.WebUtilities
@using Microsoft.JSInterop
@inject IWebHostEnvironment Environment
@inject NavigationManager NavigationManager
@inject LocalScopedDb LocalDbService
@inject CurrentUser CurrentUser
@layout BadgeFed.Components.Layouts.AdminLayout
@rendermode InteractiveServer

@attribute [Authorize(Roles = "admin, manager, manager-limited")]

<style>
    /* ── Table ─── */
    .grants-table thead th {
        background: rgba(109, 91, 208, 0.06);
        border-bottom: 2px solid rgba(94, 77, 173, 0.14);
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--admin-ink-muted);
        padding: 0.7rem 0.85rem;
        white-space: nowrap;
        font-weight: 700;
    }

    .grants-table tbody tr {
        transition: background 120ms ease;
    }

    .grants-table tbody tr:hover {
        background: rgba(109, 91, 208, 0.04);
    }

    .grants-table tbody td {
        vertical-align: middle;
        padding: 0.65rem 0.85rem;
        border-bottom: 1px solid rgba(94, 77, 173, 0.08);
        color: var(--admin-ink);
        font-size: 0.9rem;
    }

    /* ── Recipient column ─── */
    .issued-to-column {
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .issued-to-column a {
        display: block;
        max-width: 100%;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: var(--admin-accent);
        font-weight: 600;
    }

    /* ── Status pills ─── */
    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.3rem;
        padding: 0.25rem 0.7rem;
        border-radius: 999px;
        font-size: 0.74rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        white-space: nowrap;
    }

    .status-pill.pending  { background: rgba(244, 211, 124, 0.22); color: #7a5800; }
    .status-pill.accepted { background: rgba(43, 110, 210, 0.12);  color: #1a56a0; }
    .status-pill.processed{ background: var(--admin-success-soft);  color: var(--admin-success); }
    .status-pill.external { background: rgba(94, 77, 173, 0.1);    color: var(--admin-accent); }

    .auto-pill {
        display: inline-flex;
        align-items: center;
        gap: 0.2rem;
        padding: 0.18rem 0.55rem;
        border-radius: 999px;
        font-size: 0.68rem;
        font-weight: 600;
        background: rgba(109, 91, 208, 0.08);
        color: var(--admin-accent);
        margin-top: 0.3rem;
    }

    /* ── Actions ─── */
    .actions-cell { min-width: 220px; }

    .actions-wrapper {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        flex-wrap: wrap;
    }

    .action-sep {
        width: 1px;
        height: 1.1rem;
        background: rgba(94, 77, 173, 0.15);
        margin: 0 0.1rem;
    }

    /* ── Tabs ─── */
    .grant-tabs {
        display: flex;
        gap: 0.25rem;
        border-bottom: 2px solid rgba(94, 77, 173, 0.12);
        margin-bottom: 1.25rem;
    }

    .grant-tab {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.6rem 1rem;
        border-radius: 10px 10px 0 0;
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--admin-ink-muted);
        cursor: pointer;
        background: none;
        border: none;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: color 120ms ease, background 120ms ease;
    }

    .grant-tab:hover {
        color: var(--admin-ink);
        background: rgba(109, 91, 208, 0.05);
    }

    .grant-tab.is-active {
        color: var(--admin-accent);
        border-bottom-color: var(--admin-accent);
        background: rgba(109, 91, 208, 0.06);
    }

    .grant-tab .tab-count {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 1.4rem;
        height: 1.4rem;
        padding: 0 0.35rem;
        border-radius: 999px;
        font-size: 0.72rem;
        font-weight: 700;
        background: rgba(109, 91, 208, 0.1);
        color: var(--admin-accent);
    }

    .grant-tab.is-active .tab-count {
        background: var(--admin-accent);
        color: #fff;
    }

    /* ── Records summary bar ─── */
    .records-bar {
        display: flex;
        align-items: center;
        padding: 0.55rem 0.85rem;
        background: rgba(109, 91, 208, 0.05);
        border-radius: var(--admin-radius-sm);
        margin-bottom: 1rem;
        font-size: 0.84rem;
        color: var(--admin-ink-muted);
        border: 1px solid rgba(94, 77, 173, 0.1);
    }

    /* ── Copy toast ─── */
    .copy-toast {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        background: var(--admin-ink);
        color: #fff;
        padding: 0.7rem 1.15rem;
        border-radius: var(--admin-radius-sm);
        font-size: 0.875rem;
        z-index: 1000;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        box-shadow: 0 8px 24px rgba(30, 17, 64, 0.22);
        animation: fadeInUp 0.2s ease, fadeOut 0.3s ease 1.7s forwards;
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@keyframes fadeOut {
        from { opacity: 1; }
        to   { opacity: 0; }
    }
</style>
<h1>Manage Badge Grant Records</h1>

<div class="box">
    <div class="columns">
        <div class="column">
            <div class="field">
                <label class="label">Search:</label>
                <div class="control">
                    <input class="input" @bind="searchTerm" placeholder="Search title, recipient, issuer..." />
                </div>
            </div>
        </div>
        <div class="column">
            <div class="field">
                <label class="label">Issued By:</label>
                <div class="control">
                    <div class="select is-fullwidth">
                        <select @bind="issuerFilter">
                            <option value="">All</option>
                            @foreach (var actor in actors.Values)
                            {
                                <option value="@actor.Uri">@actor.FullName</option>
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>
        <div class="column">
            <div class="field">
                <label class="label">Date Range:</label>
                <div class="control">
                    <input type="date" class="input" @bind="dateFromFilter" />
                </div>
            </div>
        </div>
        <div class="column">
            <div class="field">
                <label class="label">To:</label>
                <div class="control">
                    <input type="date" class="input" @bind="dateToFilter" />
                </div>
            </div>
        </div>
    </div>
    <div class="columns">
        <div class="column">
            <div class="buttons">
                <button class="button is-primary" @onclick="OnApplyFilters">Apply Filters</button>
                <button class="button" @onclick="ClearFilters">Clear Filters</button>
            </div>
        </div>
    </div>
</div>

<div class="grant-tabs">
    <button class="grant-tab @(activeTab == "pending" ? "is-active" : "")" @onclick='() => SetActiveTab("pending")'>
        <span class="icon is-small"><i class="fas fa-clock"></i></span>
        <span>Pending</span>
        <span class="tab-count">@GetStatusCount("pending")</span>
    </button>
    <button class="grant-tab @(activeTab == "accepted" ? "is-active" : "")" @onclick='() => SetActiveTab("accepted")'>
        <span class="icon is-small"><i class="fas fa-check"></i></span>
        <span>Accepted</span>
        <span class="tab-count">@GetStatusCount("accepted")</span>
    </button>
    <button class="grant-tab @(activeTab == "processed" ? "is-active" : "")" @onclick='() => SetActiveTab("processed")'>
        <span class="icon is-small"><i class="fas fa-cogs"></i></span>
        <span>Processed</span>
        <span class="tab-count">@GetStatusCount("processed")</span>
    </button>
    <button class="grant-tab @(activeTab == "external" ? "is-active" : "")" @onclick='() => SetActiveTab("external")'>
        <span class="icon is-small"><i class="fas fa-external-link-alt"></i></span>
        <span>External</span>
        <span class="tab-count">@GetStatusCount("external")</span>
    </button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="notification is-danger">
        <button class="delete" @onclick="() => errorMessage = null"></button>
        @errorMessage
    </div>
}

@if (records == null)
{
    <p>Loading...</p>
}
else
{
    <div class="status-tab-content">
        <div class="records-bar">
            @if (filteredRecords.Count > 0)
            {
                <span>Showing <strong>@((currentPage - 1) * PageSize + 1)–@(Math.Min(currentPage * PageSize, filteredRecords.Count))</strong> of <strong>@filteredRecords.Count</strong> records</span>
            }
            else
            {
                <span>No records found</span>
            }
        </div>
        <table class="table grants-table is-fullwidth">
        <thead>
            <tr>
                <th>ID</th>
                <th>Badge</th>
                <th>Recipient</th>
                <th>Issuer</th>
                <th>Issued</th>
                <th>Status</th>
                <th class="actions-cell">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var record in pagedRecords)
            {
                var actorName = actors.ContainsKey(record.IssuedBy) 
                    ? actors[record.IssuedBy].FullName 
                    : record.IssuedBy.Substring(record.IssuedBy.LastIndexOf('/') + 1);
                var status = GetRecordStatus(record);
                
                <tr>
                    <td>@record.Id</td>
                    <td><strong>@record.Title</strong></td>
                    <td class="issued-to-column">
                        @if (!string.IsNullOrEmpty(record.IssuedToSubjectUri))
                        {
                            <a href="@record.IssuedToSubjectUri">@(
                                string.IsNullOrEmpty(record.IssuedToName) ?
                                    string.IsNullOrEmpty(record.IssuedToSubjectUri) ?
                                        MaskEmail(record.IssuedToEmail) :
                                        record.IssuedToSubjectUri
                                        : record.IssuedToName)</a>
                        }
                        else
                        {
                            @(string.IsNullOrEmpty(record.IssuedToName) ?
                                MaskEmail(record.IssuedToEmail) :
                                record.IssuedToName)
                        }
                    </td>
                    <td><a href="@record.IssuedBy">@actorName</a></td>
                    <td>@record.IssuedOn.ToString("MMM d, yyyy")</td>
                    <td>
                        @switch (status)
                        {
                            case "pending":
                                <span class="status-pill pending">
                                    <i class="fas fa-clock"></i> Pending
                                </span>
                                @if (!record.NotifiedOfGrant)
                                {
                                    <br/>
                                    <span class="auto-pill" title="Notification will be sent automatically by the job queue">
                                        <i class="fas fa-robot"></i> Auto-notify queued
                                    </span>
                                }
                                break;
                            case "accepted":
                                <span class="status-pill accepted">
                                    <i class="fas fa-check"></i> Accepted
                                </span>
                                <br/>
                                <span class="auto-pill" title="Processing will happen automatically via the job queue">
                                    <i class="fas fa-robot"></i> Auto-process queued
                                </span>
                                break;
                            case "processed":
                                <span class="status-pill processed">
                                    <i class="fas fa-check-double"></i> Processed
                                </span>
                                break;
                            case "external":
                                <span class="status-pill external">
                                    <i class="fas fa-globe"></i> External
                                </span>
                                break;
                        }
                    </td>
                    <td class="actions-cell">
                        <div class="actions-wrapper">
                        @if (record.IsExternal) 
                        {
                            <a href="@record.NoteId" target="_blank" class="button is-small is-info is-light" title="View on original server">
                                <span class="icon"><i class="fas fa-external-link-alt"></i></span>
                                <span>View</span>
                            </a>
                        } 
                        else if (string.IsNullOrEmpty(record.AcceptKey)) 
                        {
                            if (string.IsNullOrEmpty(record.FingerPrint)) 
                            {
                                <a href="/admin/grant/@record.Id/process" class="button is-small is-primary" title="Process this grant now">
                                    <span class="icon"><i class="fas fa-play"></i></span>
                                    <span>Process Now</span>
                                </a>
                            } 
                            else 
                            {
                                <a href="@record.NoteId" target="_blank" class="button is-small is-info is-light" title="View badge post">
                                    <span class="icon"><i class="fas fa-eye"></i></span>
                                    <span>View</span>
                                </a>
                            }
                        } 
                        else 
                        {
                            <button class="button is-small is-link is-light" title="Copy acceptance link to clipboard" @onclick="() => CopyAcceptLink(record)">
                                <span class="icon"><i class="fas fa-copy"></i></span>
                                <span>Copy Link</span>
                            </button>
                            <a href="/accept/grant/@record.Id/@record.AcceptKey" target="_blank" class="button is-small is-link is-outlined" title="Open acceptance page">
                                <span class="icon"><i class="fas fa-external-link-alt"></i></span>
                            </a>
                        }

                        @{
                            bool canDelete = (!record.AcceptedOn.HasValue && string.IsNullOrEmpty(record.FingerPrint)) || record.IsExternal;
                        }

                        <span class="action-sep"></span>

                        @if (canDelete) 
                        {
                            <button class="button is-small is-danger is-outlined" @onclick="() => ShowDeleteConfirmation(record)" title="@(record.IsExternal ? "Delete local copy" : "Permanently delete this grant")">
                                <span class="icon"><i class="fas fa-trash-alt"></i></span>
                                <span>@(record.IsExternal ? "Delete Local" : "Delete")</span>
                            </button>
                        } 
                        else 
                        {
                            <button class="button is-small is-warning is-outlined" @onclick="() => ShowRevokeConfirmation(record)" title="Revoke this badge grant">
                                <span class="icon"><i class="fas fa-ban"></i></span>
                                <span>Revoke</span>
                            </button>
                        }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
        </table>

        @if (TotalPages > 1)
        {
            <nav class="pagination is-centered mt-4" role="navigation" aria-label="pagination">
                <button class="pagination-previous" disabled="@(currentPage <= 1)" @onclick="PreviousPage">Previous</button>
                <button class="pagination-next" disabled="@(currentPage >= TotalPages)" @onclick="NextPage">Next page</button>
                <ul class="pagination-list">
                    @{
                        var pages = GetPaginationPages();
                    }
                    @foreach (var p in pages)
                    {
                        if (p == -1)
                        {
                            <li><span class="pagination-ellipsis">&hellip;</span></li>
                        }
                        else
                        {
                            var pageNum = p;
                            <li>
                                <button class="pagination-link @(pageNum == currentPage ? "is-current" : "")" @onclick="() => GoToPage(pageNum)">@pageNum</button>
                            </li>
                        }
                    }
                </ul>
            </nav>
        }
    </div>

    @if (showCopyToast)
    {
        <div class="copy-toast">
            <span class="icon"><i class="fas fa-check"></i></span> Accept link copied to clipboard
        </div>
    }
}

@if (showRevokeConfirmation && recordToDelete != null)
{
     <div class="modal is-active">
        <div class="modal-background" @onclick="HideRevokeConfirmation"></div>
        <div class="modal-card">
            <header class="modal-card-head">
                <p class="modal-card-title">Confirm Revocation</p>
                <button class="delete" aria-label="close" @onclick="HideRevokeConfirmation"></button>
            </header>
            <section class="modal-card-body">
                <p>Are you sure you want to revoke the badge grant "<strong>@recordToDelete.Title</strong>" issued to <strong>@recordToDelete.IssuedToName</strong>?</p>
                    <p class="has-text-danger mt-3">
                        <strong>This action cannot be undone.</strong> 
                        The grant will be revoked immediately on this server.
                        A notification will be sent to the network to initiate revocation on other sites.
                        However, due to the decentralized nature of the system, the revocation on other sites may not be immediate and depends on their processing schedules.
                    </p>
            </section>
            <footer class="modal-card-foot">
                <button class="button is-danger" @onclick="ConfirmRevoke">Revoke</button>
                <button class="button" @onclick="HideRevokeConfirmation">Cancel</button>
            </footer>
        </div>
    </div>
}

<!-- Delete Confirmation Modal -->
@if (showDeleteConfirmation && recordToDelete != null)
{
    <div class="modal is-active">
        <div class="modal-background" @onclick="HideDeleteConfirmation"></div>
        <div class="modal-card">
            <header class="modal-card-head">
                <p class="modal-card-title">Confirm Delete</p>
                <button class="delete" aria-label="close" @onclick="HideDeleteConfirmation"></button>
            </header>
            <section class="modal-card-body">
                @if (recordToDelete.IsExternal)
                {
                    <div class="notification is-warning">
                        <strong>Warning:</strong> This is an external badge grant. Deleting it locally will not remove the grant from the original server. 
                        This action only removes the record from your local database and will not affect the original badge on the issuing server.
                    </div>
                }
                <p>Are you sure you want to delete the badge grant "<strong>@recordToDelete.Title</strong>" issued to <strong>@recordToDelete.IssuedToName</strong>?</p>
                @if (!recordToDelete.IsExternal)
                {
                    <p class="has-text-danger mt-3">
                        <strong>This action cannot be undone.</strong> The grant will be permanently removed and the recipient will no longer be able to accept it.
                    </p>
                }
            </section>
            <footer class="modal-card-foot">
                <button class="button is-danger" @onclick="ConfirmDelete">Delete</button>
                <button class="button" @onclick="HideDeleteConfirmation">Cancel</button>
            </footer>
        </div>
    </div>
}

@code {
    private List<BadgeRecord?> records;
    private List<BadgeRecord?> filteredRecords = new List<BadgeRecord?>();
    private List<BadgeRecord?> pagedRecords = new List<BadgeRecord?>();

    private Dictionary<string, Actor> actors;

    private string errorMessage;

    // Filter properties
    private string searchTerm = "";
    private string issuerFilter = "";
    private DateTime? dateFromFilter;
    private DateTime? dateToFilter;
    
    // Tab properties
    private string activeTab = "pending";

    // Pagination properties
    private int currentPage = 1;
    private const int PageSize = 50;
    private int TotalPages => filteredRecords.Count == 0 ? 1 : (int)Math.Ceiling((double)filteredRecords.Count / PageSize);

    // Delete confirmation modal properties
    private bool showDeleteConfirmation = false;
    private bool showRevokeConfirmation = false;
    private BadgeRecord? recordToDelete = null;
    private bool showCopyToast = false;

    private string MaskEmail(string email) {
        if (string.IsNullOrEmpty(email)) return "";

        var atIndex = email.IndexOf('@');
        if (atIndex <= 1) return "****" + email.Substring(atIndex);

        return email.Substring(0, 1) + "****" + email.Substring(atIndex - 1);
    }

    private void PerformSearch() {
        var filter = new LocalDbService.Filter();

        var whereClauses = new List<string>() {
            "RevokedAt IS NULL"
        };

        if (!string.IsNullOrEmpty(searchTerm)) {
            whereClauses.Add("(br.Title LIKE @Term OR br.IssuedToSubjectUri LIKE @Term OR br.IssuedBy LIKE @Term)");
            filter.Parameters.Add("Term", $"%{searchTerm}%");
        }

        if (!CurrentUser.IsAdmin()) {
            whereClauses.Add("b.OwnerId = @OwnerId");
            filter.Parameters.Add("OwnerId", CurrentUser.GetGroupId());
        }

        filter.Where = string.Join(" AND ", whereClauses);
        
        records = LocalDbService.GetBadgeRecords(filter, true)!;
    }

    private void ApplyFilters() {
        PerformSearch();

        if (records == null) return;
        
        filteredRecords = records.Where(r => {
            bool matchesStatus = GetRecordStatus(r) == activeTab;
            bool matchesIssuer = string.IsNullOrEmpty(issuerFilter) || r.IssuedBy == issuerFilter;
            bool matchesDateFrom = !dateFromFilter.HasValue || r.IssuedOn >= dateFromFilter.Value;
            bool matchesDateTo = !dateToFilter.HasValue || r.IssuedOn <= dateToFilter.Value.AddDays(1);
            
            return matchesStatus && matchesIssuer && matchesDateFrom && matchesDateTo;
        })
        .OrderByDescending(r => r.IssuedOn)
        .ToList();

        // Ensure currentPage is valid
        if (currentPage > TotalPages) currentPage = TotalPages;
        if (currentPage < 1) currentPage = 1;

        pagedRecords = filteredRecords
            .Skip((currentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();
    }

    private void OnApplyFilters() {
        currentPage = 1;
        ApplyFilters();
        UpdateUrl();
    }

    private void ClearFilters() {
        searchTerm = "";
        issuerFilter = "";
        dateFromFilter = null;
        dateToFilter = null;
        currentPage = 1;
        
        ApplyFilters();
        UpdateUrl();
    }

    private string GetRecordStatus(BadgeRecord record) {
        if (record.IsExternal) {
            return "external";
        } else if (!string.IsNullOrEmpty(record.FingerPrint)) {
            return "processed";
        } else if (record.AcceptedOn.HasValue) {
            return "accepted";
        } else {
            return "pending";
        }
    }

    private async Task CopyAcceptLink(BadgeRecord record)
    {
        var link = $"{NavigationManager.BaseUri}accept/grant/{record.Id}/{record.AcceptKey}";
        await CopyToClipboard(link);
        showCopyToast = true;
        StateHasChanged();
        await Task.Delay(2000);
        showCopyToast = false;
        StateHasChanged();
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private async Task CopyToClipboard(string text)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
        currentPage = 1;
        ApplyFilters();
        UpdateUrl();
    }
    
    private int GetStatusCount(string status)
    {
        if (records == null) return 0;
        return records.Count(r => GetRecordStatus(r) == status);
    }

    protected override async Task OnInitializedAsync()
    {
        var actorList = CurrentUser.IsAdmin()
            ? LocalDbService.GetActors()
            : LocalDbService.GetActors($"OwnerId = '{CurrentUser.GetGroupId()}'");
        actors = actorList
            .Where(a => a.Uri != null)
            .GroupBy(a => a.Uri!.ToString())
            .ToDictionary(group => group.Key, group => group.First());

        ParseQueryParameters();
        ApplyFilters();
    }

    private void ParseQueryParameters()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("search", out var search)) searchTerm = search.ToString();
        if (query.TryGetValue("issuer", out var issuer)) issuerFilter = issuer.ToString();
        if (query.TryGetValue("tab", out var tab))
        {
            var tabVal = tab.ToString();
            if (tabVal is "pending" or "accepted" or "processed" or "external")
                activeTab = tabVal;
        }
        if (query.TryGetValue("from", out var from) && DateTime.TryParse(from.ToString(), out var fromDate))
            dateFromFilter = fromDate;
        if (query.TryGetValue("to", out var to) && DateTime.TryParse(to.ToString(), out var toDate))
            dateToFilter = toDate;
        if (query.TryGetValue("page", out var page) && int.TryParse(page.ToString(), out var pageNum) && pageNum > 0)
            currentPage = pageNum;
    }

    private void UpdateUrl()
    {
        var url = "/admin/grants";
        if (!string.IsNullOrEmpty(searchTerm))
            url = QueryHelpers.AddQueryString(url, "search", searchTerm);
        if (!string.IsNullOrEmpty(issuerFilter))
            url = QueryHelpers.AddQueryString(url, "issuer", issuerFilter);
        if (activeTab != "pending")
            url = QueryHelpers.AddQueryString(url, "tab", activeTab);
        if (dateFromFilter.HasValue)
            url = QueryHelpers.AddQueryString(url, "from", dateFromFilter.Value.ToString("yyyy-MM-dd"));
        if (dateToFilter.HasValue)
            url = QueryHelpers.AddQueryString(url, "to", dateToFilter.Value.ToString("yyyy-MM-dd"));
        if (currentPage > 1)
            url = QueryHelpers.AddQueryString(url, "page", currentPage.ToString());

        NavigationManager.NavigateTo(url, replace: true);
    }

    private void GoToPage(int page)
    {
        currentPage = page;
        ApplyFilters();
        UpdateUrl();
    }

    private void PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            ApplyFilters();
            UpdateUrl();
        }
    }

    private void NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
            ApplyFilters();
            UpdateUrl();
        }
    }

    private List<int> GetPaginationPages()
    {
        var pages = new List<int>();
        var total = TotalPages;

        if (total <= 7)
        {
            for (int i = 1; i <= total; i++) pages.Add(i);
            return pages;
        }

        pages.Add(1);
        if (currentPage > 3) pages.Add(-1);

        for (int i = Math.Max(2, currentPage - 1); i <= Math.Min(total - 1, currentPage + 1); i++)
            pages.Add(i);

        if (currentPage < total - 2) pages.Add(-1);
        pages.Add(total);

        return pages;
    }

    private void ShowDeleteConfirmation(BadgeRecord record)
    {
        recordToDelete = record;
        showDeleteConfirmation = true;  
    }

    private void ShowRevokeConfirmation(BadgeRecord record)
    {
        // For simplicity, using the same modal for revoke confirmation
        recordToDelete = record;
        showRevokeConfirmation = true;
    }

    private void HideRevokeConfirmation()
    {
        recordToDelete = null;
        showRevokeConfirmation = false;
    }

    private void HideDeleteConfirmation()
    {
        recordToDelete = null;
        showDeleteConfirmation = false;
    }

    private void ConfirmRevoke()
    {
        if (recordToDelete != null)
        {
            try
            {
                LocalDbService.RevokeGrantById(recordToDelete.Id);
                
                // Refresh the data
                PerformSearch();
                ApplyFilters();
                
                HideRevokeConfirmation();
            }
            catch (Exception ex)
            {
                errorMessage = $"Error revoking badge record: {ex.Message}";
            }
        }
    }

    private void ConfirmDelete()
    {
        if (recordToDelete != null)
        {
            try
            {
                LocalDbService.DeleteBadgeRecord(recordToDelete.Id);
                
                // Refresh the data
                PerformSearch();
                ApplyFilters();
                
                HideDeleteConfirmation();
            }
            catch (Exception ex)
            {
                errorMessage = $"Error deleting badge record: {ex.Message}";
            }
        }
    }
}
