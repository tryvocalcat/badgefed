@page "/admin/badges/create"
@page "/admin/badges/edit/{badgeId}"
@using BadgeFed.Services
@inject IWebHostEnvironment Environment
@inject ICustomAssetPathService CustomAssetPathService
@inject NavigationManager NavigationManager
@inject LocalScopedDb LocalDbService
@inject IConfiguration Configuration

@inject CurrentUser CurrentUser
@inject IBillingService BillingService
@rendermode InteractiveServer

@layout BadgeFed.Components.Layouts.AdminLayout

@attribute [Authorize(Roles = "admin, manager, manager-limited")]

@if (string.IsNullOrEmpty(BadgeId))
{
    <h1>Create New Badge</h1>
} else {
    <h1>Edit Badge @BadgeId - @Model.Title </h1>
}

@if (isAtBadgeLimit && string.IsNullOrEmpty(BadgeId))
{
    <section class="section pt-0">
        <LimitReachedBanner ResourceName="badge" Max="@OpenRegistrationService.MaxBadgesForLimitedManager" UpgradeUrl="@upgradeUrl" />
    </section>
}
else
{
<EditForm Model="Model" OnValidSubmit="HandleValidSubmit" OnInvalidSubmit="HandleInvalidSubmit" FormName="badgeForm">
    <DataAnnotationsValidator />

    @if (showValidationErrors)
    {
        <div class="notification is-danger is-light mb-4">
            <button class="delete" @onclick="() => showValidationErrors = false"></button>
            <p class="has-text-weight-bold mb-2">Please fix the following errors:</p>
            <ValidationSummary />
        </div>
    }

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="notification is-danger is-light mb-4">
            <button class="delete" @onclick="() => errorMessage = null"></button>
            <p>@errorMessage</p>
        </div>
    }

    <p class="help is-size-7 mb-4"><span class="has-text-danger">*</span> Required fields</p>

    <div class="field">
        <label class="label" for="title">Title <span class="has-text-danger">*</span></label>
        <div class="control">
            <InputText id="name" @bind-Value="Model!.Title" class="input" />
        </div>
        <ValidationMessage For="@(() => Model.Title)" class="help is-danger" />
    </div>

    <div class="field">
        <label class="label" for="description">Description <span class="has-text-danger">*</span></label>
        <div class="control">
            <InputTextArea id="description" @bind-Value="Model.Description" rows="4" class="textarea" />
        </div>
        <ValidationMessage For="@(() => Model.Description)" class="help is-danger" />
    </div>

    <div class="columns">
        <div class="column is-half">
            <div class="field">
                <label class="label" for="avatar">Badge Image <span class="has-text-danger">*</span></label>
                <div class="control">
                    <div class="file has-name">
                        <label class="file-label">
                            <InputFile id="avatar" OnChange="HandleFileSelection" accept="image/*" class="file-input" />
                            <span class="file-cta">
                                <span class="file-icon">
                                    <i class="fas fa-upload"></i>
                                </span>
                                <span class="file-label">Choose a file…</span>
                            </span>
                            <span class="file-name">@(selectedFile?.Name ?? "No file selected")</span>
                        </label>
                    </div>
                </div>
                <p class="help is-size-7 mt-1">
                    A default badge image is provided. Upload your own to replace it.
                    Accepted formats: PNG, JPEG, GIF, WebP. Max file size: 10 MB. The image will be resized to 300×300 pixels and converted to PNG.
                </p>
                @if (imagePreview != null)
                {
                    <div class="mt-3">
                        <img src="@imagePreview" alt="Avatar Preview" style="max-width: 200px; max-height: 200px;" />
                    </div>
                }
            </div>
        </div>
        <div class="column is-half">
            <div class="field">
                <label class="label" for="imageAltText">Image alt text</label>
                <div class="control">
                    <InputTextArea id="imageAltText" @bind-Value="Model.ImageAltText" rows="12" class="textarea" />
                </div>
                <ValidationMessage For="@(() => Model.ImageAltText)" class="help is-danger" />
            </div>
        </div>
    </div>

    <div class="field">
        <label class="label" for="earningCriteria">Earning Criteria <span class="has-text-danger">*</span></label>
        <div class="control">
            <InputTextArea id="earningCriteria" @bind-Value="Model.EarningCriteria" rows="4" class="textarea" />
        </div>
        <ValidationMessage For="@(() => Model.EarningCriteria)" class="help is-danger" />
    </div>

    <div class="field">
        <label class="label" for="infoUri">More Information URL <span class="has-text-danger">*</span></label>
        <div class="control">
            <InputText 
                id="infoUri" 
                @bind-Value="Model.InfoUri" 
                class="input" 
                placeholder="https://example.com/program-info" 
                type="url"
            />
        </div>
        <p class="help is-size-7 mt-1">
            Add a URL where recipients can learn more about this badge or the program behind it. Must be a valid URL if provided.
        </p>
        <ValidationMessage For="@(() => Model.InfoUri)" class="help is-danger" />
    </div>

    <div class="field">
        <label class="label" for="hashtags">Hashtags</label>
        <div class="control">
            <InputText 
                id="hashtags" 
                @bind-Value="Model.Hashtags" 
                class="input" 
                placeholder="e.g. #achievement #certification" 
            />
        </div>
        <p class="help is-size-7 mt-1">
            Enter hashtags with a <code>#</code> prefix, separated by spaces.
        </p>
        <p class="help is-size-7 mb-1">
            <strong>Note:</strong> All badges will automatically include 
            <code>#IssuedByBadgeFed</code> and <code>#BadgeDrop</code> to help others filter badge posts.
        </p>
        <p class="help is-danger is-size-7 mt-2">
            <strong>Warning:</strong> Submitting a large batch of badges at once may flood followers' timelines. 
            Please select hashtags carefully to avoid spam-like behavior.
        </p>
    </div>

    
    <div class="field">
        <label class="label" for="issuedBy">Issued By <span class="has-text-danger">*</span></label>
        <div class="control">
            <div class="select is-fullwidth">
                <InputSelect id="actorId" @bind-Value="Model.IssuedBy">
                    <option value="0">-- Select an issuer --</option>
                    @foreach (var actor in actors)
                    {
                        <option value="@actor.Id">@actor.FullName - @actor.Username @actor.Domain</option>
                    }
                </InputSelect>
            </div>
        </div>
        <ValidationMessage For="@(() => Model.IssuedBy)" class="help is-danger" />
    </div>

    <div class="field">
        <label class="label">Badge Type <span class="has-text-danger">*</span></label>
        <div class="control">
            <div class="select is-fullwidth">
                <InputSelect id="badgeType" @bind-Value="Model.BadgeType">
                    @foreach (var badgeType in Badge.BadgeTypes)
                    {
                        <option value="@badgeType">@badgeType</option>
                    }
                </InputSelect>
            </div>
        </div>
    </div>

    <div class="field">
        <div class="control">
            <label class="checkbox">
                <InputCheckbox @bind-Value="Model.IsCertificate" />
                Display as Certificate/Diploma
            </label>
        </div>
        <p class="help is-size-7 mt-1">
            Check this option if you want this badge to be displayed as a certificate or diploma format instead of a regular badge.
        </p>
    </div>

    <div class="field is-grouped mt-5">
        <div class="control">
            <button type="submit" class="button is-primary" disabled="@isSubmitting">
                @if (isSubmitting)
                {
                    <span class="icon is-small">
                        <i class="fas fa-spinner fa-spin"></i>
                    </span>
                    <span>Creating...</span>
                }
                else
                {
                    
                    @if (string.IsNullOrEmpty(BadgeId))
                    {
                        <span>Create Badge</span>
                    } else {
                        <span>Update Badge</span>
                    }
                }
            </button>
        </div>
        <div class="control">
            <button @onclick="ClearForm" type="button" class="button is-light">Clear form</button>
        </div>
    </div>
</EditForm>
}

@code {

    [Parameter]
    public string BadgeId { get; set; }

    private Badge? Model = new();

    private IBrowserFile? selectedFile;
    private string? imagePreview;
    private string? errorMessage;
    private bool isSubmitting = false;
    private bool isAtBadgeLimit;
    private bool showValidationErrors = false;
    private string? upgradeUrl;

    private List<Actor> actors;

    private const string DefaultBadgeImage = "/defaultbadge.jpg";

    protected override void OnInitialized()
    {
        FetchActors();

        if (!string.IsNullOrEmpty(BadgeId)) {
            var id = long.Parse(BadgeId);
            Model = LocalDbService.GetBadgeById(id);
        }

        if (string.IsNullOrEmpty(Model.Image))
        {
            Model.Image = DefaultBadgeImage;
        }
        imagePreview = Model.Image;
    }

    protected override async Task OnInitializedAsync()
    {
        if (IsLimitedManager() && string.IsNullOrEmpty(BadgeId))
        {
            var badgeList = LocalDbService.GetAllBadgeDefinitions(true, $"a.OwnerId = '{CurrentUser.GetGroupId()}'");
            var hasSubscription = await CurrentUser.HasActiveSubscription();
            isAtBadgeLimit = !hasSubscription && badgeList.Count >= OpenRegistrationService.MaxBadgesForLimitedManager;
            if (isAtBadgeLimit)
                upgradeUrl = await BillingService.GetCheckoutUrl(CurrentUser.GetGroupId(), "/admin/badges/create");
        }
    }

    private bool IsLimitedManager() =>
        CurrentUser.GetRole().Equals(OpenRegistrationService.LimitedManagerRole, StringComparison.OrdinalIgnoreCase);

    private void FetchActors()
    {
        if (CurrentUser.IsAdmin())
        {
            actors = LocalDbService.GetActors();
        }
        else
        {
            actors = LocalDbService.GetActors($"OwnerId = '{CurrentUser.GetGroupId()}'");
        }
    }

    private void ClearForm()
    {
        Model = new() { Image = DefaultBadgeImage };
        selectedFile = null;
        imagePreview = DefaultBadgeImage;
    }

    private void HandleInvalidSubmit()
    {
        showValidationErrors = true;
    }

    private async Task HandleFileSelection(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        selectedFile = e.File;

        var maxAllowedSize = 10 * 1024 * 1024;

        if (selectedFile.Size > maxAllowedSize)
        {
            errorMessage = "File size exceeds 10 MB limit.";
            selectedFile = null;
            return;
        }

        try
        {
            var format = "image/png";
            var resizedImage = await selectedFile.RequestImageFileAsync(format, 300, 300);
            using var stream = resizedImage.OpenReadStream(maxAllowedSize: maxAllowedSize);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var buffer = ms.ToArray();

            imagePreview = $"data:{format};base64,{Convert.ToBase64String(buffer)}";
        }
        catch (Exception ex)
        {
            errorMessage = "Failed to process image. Please try a smaller file or a different format.";
            selectedFile = null;
            imagePreview = DefaultBadgeImage;
        }
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        if (isAtBadgeLimit && string.IsNullOrEmpty(BadgeId))
        {
            errorMessage = "You have reached your badge limit. Please upgrade your plan to create more badges.";
            return;
        }
        showValidationErrors = false;
        errorMessage = null;
        isSubmitting = true;
        try
        {
            if (selectedFile != null)
            {
                var fileName = $"{Guid.NewGuid()}.png";
                var path = CustomAssetPathService.GetBadgesPath();
                
                // Ensure directory exists
                Directory.CreateDirectory(path);
                
                var maxAllowedSize = 10 * 1024 * 1024;

                var fullPath = Path.Combine(path, fileName);
                
                // Convert and save as PNG
                var format = "image/png";
                var resizedImage = await selectedFile.RequestImageFileAsync(format, 300, 300);
                using var stream = resizedImage.OpenReadStream(maxAllowedSize: maxAllowedSize);
                using var fileStream = new FileStream(fullPath, FileMode.Create);
                await stream.CopyToAsync(fileStream);

                ImageService.ModifyImageForPageShare(fullPath);
                
                Model.Image = CustomAssetPathService.GetBadgeUrl(fileName);
            }

            Console.WriteLine($"Saving badge: {Model.Image}");

            Model.OwnerId = CurrentUser.GetGroupId();

            // TODO: Save actor to database
            LocalDbService.UpsertBadgeDefinition(Model);
            
            // Redirect to actors list or details page
            NavigationManager.NavigateTo("/admin/badges");
            
            // For demo purposes, just reset the form
            Model = new();

            selectedFile = null;
            imagePreview = null;


        }
        catch (Exception ex)
        {
            if (ex.Message.Contains("CHECK") && ex.Message.Contains("Title"))
                errorMessage = "Title must be between 2 and 100 characters.";
            else if (ex.Message.Contains("CHECK") && ex.Message.Contains("Description"))
                errorMessage = "Description cannot exceed 500 characters.";
            else if (ex.Message.Contains("CHECK") && ex.Message.Contains("EarningCriteria"))
                errorMessage = "Earning criteria cannot exceed 500 characters.";
            else if (ex.Message.Contains("CHECK") && ex.Message.Contains("ImageAltText"))
                errorMessage = "Image alt text cannot exceed 1500 characters.";
            else if (ex.Message.Contains("NOT NULL") || ex.Message.Contains("constraint"))
                errorMessage = "A required field is missing. Please check all required fields are filled in.";
            else
                errorMessage = $"Error saving badge: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }
    
}
