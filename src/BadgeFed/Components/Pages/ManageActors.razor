@page "/admin/actors"

@using System.IO
@using Microsoft.AspNetCore.Hosting
@using Microsoft.AspNetCore.Components.Forms
@inject IWebHostEnvironment Environment
@inject NavigationManager NavigationManager
@inject LocalScopedDb LocalDbService
@layout BadgeFed.Components.Layouts.AdminLayout
@rendermode InteractiveServer
@using System.Security.Claims;
@inject CurrentUser CurrentUser
@inject IBillingService BillingService

@attribute [Authorize(Roles = "admin, manager, manager-limited")]

<h1 class="title">Manage Issuers</h1>

@if (isAtIssuerLimit)
{
    <LimitReachedBanner ResourceName="issuer" Max="@OpenRegistrationService.MaxIssuersForLimitedManager" UpgradeUrl="@upgradeUrl" />
}
else
{
    <div class="mb-4 has-text-right">
        <a href="/admin/actors/create" class="button is-success">Create New Issuer</a>
    </div>
}

@if (ShowCreateBadgePrompt)
{
    <div class="first-badge-banner mb-5">
        <div class="first-badge-copy">
            <span class="first-badge-kicker">Next step</span>
            <h2 class="title is-3 mb-2">Create your first badge</h2>
            <p>
                Your issuer is ready. Now create the first badge people will actually receive from this workspace.
            </p>
            <div class="first-badge-checklist">
                <div class="first-badge-item">
                    <span class="first-badge-dot"></span>
                    <span>Choose the issuer you just created</span>
                </div>
                <div class="first-badge-item">
                    <span class="first-badge-dot"></span>
                    <span>Write the badge title, description, and criteria</span>
                </div>
                <div class="first-badge-item">
                    <span class="first-badge-dot"></span>
                    <span>Save it, then you will be ready to grant it</span>
                </div>
            </div>
        </div>
        <div class="first-badge-actions">
            <a href="/admin/badges/create" class="button is-primary is-medium first-badge-button">
                <span class="icon"><i class="fas fa-certificate"></i></span>
                <span>Create My First Badge</span>
            </a>
        </div>
    </div>
}

@if (actors == null)
{
    <div class="notification is-info is-light">
        <p>Loading...</p>
    </div>
}
else
{
    <div class="table-container">
        <table class="table is-hoverable is-fullwidth">
            <thead>
                <tr>
                    <th>Full Name</th>
                    <th>Summary</th>
                    <th>Avatar</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var actor in actors)
                {
                    <tr class="@(actor.IsMain ? "has-background-primary-light" : "")">
                        <td>@actor.FullName</td>
                        <td>@(actor.IsMain ? "A main issuer cannot issue badges by itself, and by default share all public badges in this instance." : @actor.Summary )</td>
                        <td>
                            <figure class="image is-64x64">
                                <img src="@actor.AvatarPath" alt="Avatar" class="is-rounded" />
                            </figure>
                        </td>
                        <td class="has-text-right">
                            <div class="buttons is-right">
                                <button class="button is-info is-small" @onclick="() => ViewActor(actor)">
                                    <span class="icon is-small">
                                        <i class="fas fa-eye"></i>
                                    </span>
                                    <span>View</span>
                                </button>
                                <button class="button is-primary is-small" @onclick="() => EditActor(actor)">Edit</button>
                                @if (!actor.IsMain)
                                {
                                    <button class="button is-danger is-small" @onclick="() => ShowDeleteConfirmation(actor)">Delete</button>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (showDeleteConfirmation && actorToDelete != null)
{
    <div class="modal is-active">
        <div class="modal-background" @onclick="HideDeleteConfirmation"></div>
        <div class="modal-card">
            <header class="modal-card-head">
                <p class="modal-card-title">Confirm Delete</p>
                <button class="delete" aria-label="close" @onclick="HideDeleteConfirmation"></button>
            </header>
            <section class="modal-card-body">
                <p>Are you sure you want to delete the issuer "<strong>@actorToDelete.FullName</strong>"?</p>
                <p class="has-text-danger mt-3">
                    <strong>This action cannot be undone.</strong> The issuer will be permanently removed.
                </p>
            </section>
            <footer class="modal-card-foot">
                <button class="button is-danger" @onclick="ConfirmDeleteActor">Delete</button>
                <button class="button" @onclick="HideDeleteConfirmation">Cancel</button>
            </footer>
        </div>
    </div>
}

<style>
    .first-badge-banner {
        display: flex;
        justify-content: space-between;
        gap: 1.5rem;
        align-items: center;
        padding: 1.75rem;
        border-radius: 24px;
        border: 1px solid #dceaf7;
        background: linear-gradient(140deg, #fffef7 0%, #ffffff 55%, #eef7ff 100%);
        box-shadow: 0 18px 45px rgba(21, 44, 74, 0.08);
    }

    .first-badge-copy {
        max-width: 42rem;
    }

    .first-badge-kicker {
        display: inline-flex;
        border-radius: 999px;
        background: #15304a;
        color: white;
        padding: 0.35rem 0.75rem;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        margin-bottom: 0.85rem;
    }

    .first-badge-checklist {
        display: grid;
        gap: 0.6rem;
        margin-top: 1rem;
    }

    .first-badge-item {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        color: #4f6074;
        font-weight: 500;
    }

    .first-badge-dot {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: #1f6feb;
        flex: 0 0 auto;
    }

    .first-badge-actions {
        flex: 0 0 auto;
    }

    .first-badge-button {
        min-height: 3.25rem;
        border-radius: 999px;
        padding-left: 1.25rem;
        padding-right: 1.25rem;
        font-weight: 700;
        box-shadow: 0 12px 28px rgba(31, 111, 235, 0.16);
    }

    @@media (max-width: 768px) {
        .first-badge-banner {
            flex-direction: column;
            align-items: flex-start;
        }

        .first-badge-actions {
            width: 100%;
        }

        .first-badge-button {
            width: 100%;
        }
    }
</style>

@code {
    private List<Actor> actors;
    private Actor? actorToDelete;
    private int ownedBadgeCount;
    private string errorMessage;
    private bool isAtIssuerLimit;
    private bool showDeleteConfirmation;
    private string? upgradeUrl;
    private bool ShowCreateBadgePrompt => !CurrentUser.IsAdmin()
        && actors != null
        && actors.Any(a => !a.IsMain)
        && ownedBadgeCount == 0;

    protected override async Task OnInitializedAsync()
    {
        FetchActors();
        if (IsLimitedManager())
        {
            var hasSubscription = await CurrentUser.HasActiveSubscription();
            isAtIssuerLimit = !hasSubscription && actors.Count >= OpenRegistrationService.MaxIssuersForLimitedManager;
            if (isAtIssuerLimit)
                upgradeUrl = await BillingService.GetCheckoutUrl(CurrentUser.GetGroupId(), "/admin/actors");
        }
    }

    private bool IsLimitedManager() =>
        CurrentUser.GetRole().Equals(OpenRegistrationService.LimitedManagerRole, StringComparison.OrdinalIgnoreCase);

    private void FetchActors()
    {
        if (CurrentUser.IsAdmin())
        {
            actors = LocalDbService.GetActors();
            ownedBadgeCount = LocalDbService.GetAllBadgeDefinitions().Count;
        }
        else
        {
            actors = LocalDbService.GetActors($"OwnerId = '{CurrentUser.GetGroupId()}'");
            ownedBadgeCount = LocalDbService.GetAllBadgeDefinitions(true, $"a.OwnerId = '{CurrentUser.GetGroupId()}'").Count;
        }
    }

    private void EditActor(Actor actor)
    {
        Console.WriteLine($"Editing actor: {actor.Id}");
        NavigationManager.NavigateTo($"/admin/actors/edit/{actor.Id}");
    }

    private void ViewActor(Actor actor)
    {
        Console.WriteLine($"Viewing actor: {actor.Id}");
        if (!string.IsNullOrEmpty(actor.Uri?.ToString()))
        {
            // Open in new tab
            NavigationManager.NavigateTo(actor.Uri.ToString(), true);
        }
        else
        {
            // Navigate to a local actor profile page if URI is not available
            NavigationManager.NavigateTo($"/actors/{actor.Username}");
        }
    }

    private void ShowDeleteConfirmation(Actor actor)
    {
        actorToDelete = actor;
        showDeleteConfirmation = true;
    }

    private void HideDeleteConfirmation()
    {
        actorToDelete = null;
        showDeleteConfirmation = false;
    }

    private void ConfirmDeleteActor()
    {
        if (actorToDelete == null)
            return;

        Console.WriteLine($"Deleting actor: {actorToDelete.Id}");
        LocalDbService.DeleteActor(actorToDelete.Id);
        HideDeleteConfirmation();
        FetchActors();
    }

    private void MarkAsMain(Actor actor)
    {
        actor.IsMain = true;
        LocalDbService.UpsertActor(actor);
        FetchActors();
    }
}