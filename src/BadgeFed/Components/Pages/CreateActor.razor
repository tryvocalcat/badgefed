@page "/admin/actors/create"
@page "/admin/actors/edit/{actorId}"
@using System.IO
@using System.Linq
@using BadgeFed.Models
@using BadgeFed.Services
@using Microsoft.AspNetCore.Hosting
@using Microsoft.AspNetCore.Components.Forms
@inject IWebHostEnvironment Environment
@inject ICustomAssetPathService CustomAssetPathService
@inject NavigationManager NavigationManager
@inject LocalScopedDb LocalDbService
@inject IConfiguration Configuration
@inject FollowService FollowService
@inject CurrentUser CurrentUser
@inject IBillingService BillingService
@inject IHttpContextAccessor HttpContextAccessor

@rendermode InteractiveServer

@layout BadgeFed.Components.Layouts.AdminLayout

@attribute [Authorize(Roles = "admin, manager, manager-limited")]

<style>
    .form-section {
        background: white;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
        padding: 2rem;
        margin-bottom: 2rem;
    }
    .form-header {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #e9ecef;
    }
    .form-title {
        font-size: 1.5rem;
        font-weight: 600;
        color: #1a1a1a;
    }
    .form-subtitle {
        color: #6b7280;
        margin-top: 0.5rem;
    }
    .field-label {
        font-weight: 500;
        color: #374151;
        margin-bottom: 0.5rem;
    }
    .input, .textarea, .select select {
        border-radius: 8px;
        border: 2px solid #e9ecef;
        transition: all 0.2s ease;
    }
    .input:focus, .textarea:focus, .select select:focus {
        border-color: #4f46e5;
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
    }
    .file-upload {
        border: 2px dashed #e9ecef;
        border-radius: 8px;
        padding: 2rem;
        text-align: center;
        transition: all 0.2s ease;
        cursor: pointer;
    }
    .file-upload:hover {
        border-color: #4f46e5;
        background-color: rgba(79, 70, 229, 0.02);
    }
    .file-upload-icon {
        font-size: 2rem;
        color: #9ca3af;
        margin-bottom: 1rem;
    }
    .preview-image {
        max-width: 200px;
        max-height: 200px;
        border-radius: 8px;
        object-fit: cover;
        margin-top: 1rem;
    }
    .key-section {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 1rem;
        margin-top: 0.5rem;
    }
    .key-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #6b7280;
        font-size: 0.875rem;
    }
    .help-text {
        font-size: 0.875rem;
        color: #6b7280;
        margin-top: 0.25rem;
    }
    .submit-button {
        min-width: 120px;
    }
    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid #e9ecef;
    }
    .social-section {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1rem;
    }
    .social-field {
        margin-bottom: 0.75rem;
    }
    .social-field:last-child {
        margin-bottom: 0;
    }
    .required-asterisk {
        color: #e53e3e;
        margin-left: 2px;
        font-weight: bold;
    }
    .field-label.required {
        position: relative;
    }
    .warning-banner {
        background: #fef3cd;
        border: 1px solid #ffc107;
        border-radius: 8px;
        padding: 1rem 1.25rem;
        margin-bottom: 2rem;
        color: #856404;
    }
    .warning-banner .warning-icon {
        color: #ffc107;
        margin-right: 0.5rem;
        font-size: 1.25rem;
    }
    .warning-banner .warning-title {
        font-weight: 600;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
    }
    .warning-banner .warning-text {
        margin: 0;
        font-size: 0.925rem;
    }

    /* Advanced Settings */
    .advanced-toggle {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        color: #6b7280;
        font-size: 0.925rem;
        font-weight: 500;
        padding: 0.75rem 0;
        user-select: none;
        transition: color 0.2s ease;
    }
    .advanced-toggle:hover {
        color: #4f46e5;
    }
    .advanced-toggle i {
        transition: transform 0.2s ease;
        font-size: 0.75rem;
    }
    .advanced-toggle i.rotated {
        transform: rotate(90deg);
    }
    .advanced-content {
        overflow: hidden;
        max-height: 0;
        opacity: 0;
        transition: max-height 0.3s ease, opacity 0.3s ease;
    }
    .advanced-content.expanded {
        max-height: 600px;
        opacity: 1;
    }

    /* Admin Advanced Section */
    .admin-advanced-section {
        background: #fef3cd;
        border: 1px solid #ffc107;
        border-radius: 12px;
        padding: 1.5rem 2rem;
        margin-bottom: 2rem;
    }
    .admin-advanced-section .admin-section-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid #ffe082;
    }
    .admin-advanced-section .admin-section-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: #856404;
    }
    .admin-advanced-section .admin-section-icon {
        color: #b8860b;
        font-size: 1.1rem;
    }

    /* Key Status */
    .key-status-card {
        display: flex;
        align-items: center;
        gap: 1rem;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        border-radius: 8px;
        padding: 1rem 1.25rem;
        margin-bottom: 1rem;
    }
    .key-status-card.no-key {
        background: #fef3cd;
        border-color: #ffc107;
    }
    .key-status-card .key-status-icon {
        font-size: 1.5rem;
    }
    .key-status-card.no-key .key-status-icon {
        color: #b45309;
    }
    .key-status-card:not(.no-key) .key-status-icon {
        color: #16a34a;
    }
    .key-status-card .key-status-text {
        flex: 1;
    }
    .key-status-card .key-status-title {
        font-weight: 600;
        font-size: 0.925rem;
    }
    .key-status-card .key-status-desc {
        font-size: 0.825rem;
        color: #6b7280;
        margin-top: 0.15rem;
    }

    /* Confirmation Modal */
    .modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }
    .modal-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        max-width: 480px;
        width: 90%;
        overflow: hidden;
    }
    .modal-card-head {
        background: #fef2f2;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #fecaca;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .modal-card-head .modal-icon {
        color: #dc2626;
        font-size: 1.5rem;
    }
    .modal-card-head .modal-title {
        font-weight: 700;
        font-size: 1.1rem;
        color: #991b1b;
    }
    .modal-card-body {
        padding: 1.5rem;
    }
    .modal-card-body p {
        margin-bottom: 0.75rem;
        color: #374151;
        line-height: 1.6;
    }
    .modal-card-body .modal-warning-list {
        background: #fff7ed;
        border-radius: 8px;
        padding: 1rem;
        margin: 1rem 0;
    }
    .modal-card-body .modal-warning-list li {
        color: #9a3412;
        font-size: 0.9rem;
        margin-bottom: 0.35rem;
    }
    .modal-card-foot {
        padding: 1rem 1.5rem;
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        border-top: 1px solid #e9ecef;
    }
</style>

@if (isAtIssuerLimit && string.IsNullOrEmpty(ActorId))
{
    <section class="section">
        <LimitReachedBanner ResourceName="issuer" Max="@OpenRegistrationService.MaxIssuersForLimitedManager" UpgradeUrl="@upgradeUrl" />
    </section>
}

<div class="form-section">
    @if (string.IsNullOrEmpty(Model?.Domain))
    {
        <div class="warning-banner">
            <div class="warning-title">
                <i class="fas fa-exclamation-triangle warning-icon"></i>
                Domain Configuration Required
            </div>
            <p class="warning-text">
                The domain could not be automatically detected from the request. This may cause issues with actor creation and federation. Please check your server configuration or contact your administrator.
            </p>
        </div>
    }

    <div class="form-header">
                
        @if (string.IsNullOrEmpty(ActorId))
        {
            <h1 class="form-title">Create New Issuer</h1>
        } else {
            <h1 class="form-title">Edit Issuer @ActorId - @Model.FullName </h1>
        }
        <p class="form-subtitle">Set up a new actor to issue and manage badges</p>
    </div>

    <EditForm Model="Model" OnValidSubmit="HandleValidSubmit" FormName="actorForm">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <div class="columns is-multiline">
            <div class="column is-6">
            <div class="field">
                <label class="field-label required" for="name">Full Name<span class="required-asterisk">*</span></label>
                <div class="control">
                        <InputText id="name" @bind-Value="Model!.FullName" @bind-Value:after="OnFullNameChanged" class="input" placeholder="e.g. Open Badges Foundation" required />
                    </div>
                    <ValidationMessage For="@(() => Model.FullName)" class="help is-danger" />
                </div>
            </div>

            <div class="column is-6">
                <div class="field">
                    <label class="field-label required" for="username">Username<span class="required-asterisk">*</span></label>
                    
                    <div class="control">
                        @if (!string.IsNullOrEmpty(ActorId))
                        {
                            <div class="input disabled is-static">@Model.Username@@@Model.Domain</div>
                            <p class="help-text">Username cannot be changed after creation</p>
                        }
                        else
                        {
                            <InputText id="username" @bind-Value="Model!.Username" @bind-Value:after="OnUsernameChanged" class="input" placeholder="e.g. open-badges-org" required />
                            <p class="help-text">
                                Handle: <strong>@(string.IsNullOrEmpty(Model?.Username) ? "username" : Model.Username)@@@(Model?.Domain ?? "yourdomain")</strong>
                                @if (!usernameManuallyEdited && !string.IsNullOrEmpty(Model?.Username))
                                {
                                    <span style="color:#4f46e5; font-size:0.8rem; margin-left:0.5rem;">
                                        <i class="fas fa-magic" style="font-size:0.7rem;"></i> auto-suggested from name
                                    </span>
                                }
                            </p>
                        }
                    </div>
                    
                    <ValidationMessage For="@(() => Model.Username)" class="help is-danger" />
                </div>
            </div>

            <div class="column is-12">
                <div class="field">
                    <label class="field-label required" for="summary">Summary<span class="required-asterisk">*</span></label>
                    <div class="control">
                        <InputTextArea id="summary" @bind-Value="Model.Summary" @bind-Value:event="oninput" class="textarea" rows="4" placeholder="Briefly describe this issuer's purpose and the types of badges they issue" required />
                    </div>
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-top:0.25rem;">
                        <ValidationMessage For="@(() => Model.Summary)" class="help is-danger" />
                        <span class="help-text" style="color:@(Model?.Summary?.Length > 450 ? "#e53e3e" : "#9ca3af"); font-size:0.8rem;">@(Model?.Summary?.Length ?? 0) / 500</span>
                    </div>
                </div>
            </div>

            <div class="column is-6">
                <div class="field">
                    <label class="field-label" for="theme">Profile Theme</label>
                    <div class="control">
                        <div class="select is-fullwidth">
                            <InputSelect id="theme" @bind-Value="Model!.Theme">
                                <option value="default">Default - Modern Gradient</option>
                                <option value="ocean">Ocean - Blue & Teal</option>
                                <option value="forest">Forest - Green & Earth</option>
                                <option value="sunset">Sunset - Orange & Purple</option>
                                @foreach (var customTheme in GetCustomThemes())
                                {
                                    <option value="@customTheme.Key">@customTheme.Value</option>
                                }
                            </InputSelect>
                        </div>
                    </div>
                    <p class="help">Choose a visual theme for your profile page</p>
                </div>
            </div>

            <div class="column is-6">
                <div class="field">
                    <label class="field-label required" for="informationUri">Website / Profile URL<span class="required-asterisk">*</span></label>
                    <div class="control has-icons-left">
                        <InputText id="informationUri" @bind-Value="Model!.InformationUri" class="input" placeholder="https://yourdomain.com/about" type="url" />
                        <span class="icon is-left"><i class="fas fa-link"></i></span>
                    </div>
                    <p class="help-text">Public page linking to more info about this issuer</p>
                    <ValidationMessage For="@(() => Model.InformationUri)" class="help is-danger" />
                </div>
            </div>

            <div class="column is-6">
                <div class="field">
                    <label class="checkbox">
                        <InputCheckbox @bind-Value="Model!.ShowFollowers" />
                        Show Followers
                    </label>
                    <p class="help-text">When enabled, followers count and list will be displayed on your public profile</p>
                </div>
            </div>

            <!-- Social Links Section -->
            <div class="column is-12">
                <div class="field">
                    <label class="field-label">Social Links</label>
                    <p class="help-text">Add up to 3 social media links or contact methods</p>
                </div>
            </div>

            @for (int i = 0; i < 3; i++)
            {
                var index = i; // Capture for lambda
                <div class="column is-4">
                    <div class="social-section">
                        <div class="social-field">
                            <label class="field-label">Social @(index + 1) Type</label>
                            <div class="control">
                                <div class="select is-fullwidth">
                                    <select @onchange="@(e => UpdateSocialType(index, e.Value?.ToString()))" value="@GetSocialType(index)">
                                        <option value="">Select platform...</option>
                                        <option value="linkedin">LinkedIn</option>
                                        <option value="mastodon">Mastodon</option>
                                        <option value="loops">Loops</option>
                                        <option value="youtube">YouTube</option>
                                        <option value="peertube">PeerTube</option>
                                        <option value="email">Email</option>
                                        <option value="instagram">Instagram</option>
                                        <option value="pixelfed">Pixelfed</option>
                                        <option value="threads">Threads</option>
                                        <option value="github">GitHub</option>
                                        <option value="bluesky">Bluesky</option>
                                        <option value="discord">Discord</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="social-field">
                            <label class="field-label">URL/Handle</label>
                            <div class="control">
                                <input type="text" class="input" 
                                       value="@GetSocialUri(index)" 
                                       @onchange="@(e => UpdateSocialUri(index, e.Value?.ToString()))"
                                       placeholder="@GetSocialPlaceholder(index)" />
                            </div>
                        </div>
                    </div>
                </div>
            }

            <div class="column is-12">
                <div class="field">
                    <label class="field-label">Avatar</label>
                    <div class="file-upload">
                        <div class="file-upload-icon">
                            <i class="fas fa-cloud-upload-alt"></i>
                        </div>
                        <p class="has-text-grey">Click to upload or drag and drop</p>
                        <p class="help-text">PNG, JPG up to 2MB</p>
                        <InputFile id="avatar" OnChange="HandleFileSelection" accept="image/*" />
                    </div>
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <p class="help is-danger">@errorMessage</p>
                    }
                    @if (imagePreview != null)
                    {
                        <img src="@imagePreview" alt="Avatar Preview" class="preview-image" />
                    }
                </div>
            </div>

            <!-- Key Management Section -->
            <div class="column is-12">
                <div class="field">
                    <label class="field-label">Signing Keys</label>

                    @if (HasKeys())
                    {
                        <div class="key-status-card">
                            <div class="key-status-icon">
                                <i class="fas fa-shield-alt"></i>
                            </div>
                            <div class="key-status-text">
                                <div class="key-status-title">Keys configured</div>
                                <div class="key-status-desc">This issuer has a signing key pair for federation.</div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(ActorId) && HasPrivateKey())
                        {
                            <button type="button" @onclick="ShowRegenerateConfirmation" class="button is-warning is-small">
                                <span class="icon is-small"><i class="fas fa-sync-alt"></i></span>
                                <span>Regenerate Keys</span>
                            </button>
                        }
                    }
                    else
                    {
                        <div class="key-status-card no-key">
                            <div class="key-status-icon">
                                <i class="fas fa-exclamation-triangle"></i>
                            </div>
                            <div class="key-status-text">
                                <div class="key-status-title">No keys configured</div>
                                <div class="key-status-desc">A key pair will be generated automatically when you save, or you can provide your own below.</div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(ActorId))
                        {
                            <button type="button" @onclick="GenerateAndSaveKeyPair" class="button is-info is-small mt-2">
                                <span class="icon is-small"><i class="fas fa-key"></i></span>
                                <span>Generate Keys Now</span>
                            </button>
                        }
                    }

                    <!-- Advanced Settings Toggle -->
                    <div class="advanced-toggle" @onclick="ToggleAdvancedSettings">
                        <i class="fas fa-chevron-right @(showAdvancedSettings ? "rotated" : "")"></i>
                        <span>Advanced Settings — manually provide keys</span>
                    </div>

                    <div class="advanced-content @(showAdvancedSettings ? "expanded" : "")">
                        <div class="notification is-info is-light" style="border-radius: 8px; margin-bottom: 1rem; font-size: 0.9rem;">
                            <p style="margin-bottom: 0.5rem;">
                                <strong><i class="fas fa-info-circle"></i> Key requirements</strong>
                            </p>
                            <p style="margin-bottom: 0.35rem;">
                                BadgeFed uses <strong>RSA 2048-bit</strong> keys for ActivityPub federation signatures.
                                If you provide your own keys, they must meet these requirements:
                            </p>
                            <ul style="margin-left: 1.25rem; margin-top: 0.25rem; margin-bottom: 0;">
                                <li><strong>Public key</strong> — PEM-encoded, SPKI format (<code>-----BEGIN PUBLIC KEY-----</code>)</li>
                                <li><strong>Private key</strong> — PEM-encoded, PKCS#8 format (<code>-----BEGIN PRIVATE KEY-----</code>)</li>
                                <li><strong>Algorithm</strong> — RSA with a minimum key size of 2048 bits</li>
                            </ul>
                        </div>
                        <div class="columns">
                            <div class="column is-6">
                                <div class="field">
                                    <label class="field-label" for="public-key">Public Key</label>
                                    <div class="control">
                                        <InputTextArea id="public-key" @bind-Value="Model.PublicKeyPem" class="textarea" rows="6" placeholder="-----BEGIN PUBLIC KEY-----&#10;MIIBIjANBgkqhkiG9w...&#10;-----END PUBLIC KEY-----" />
                                    </div>
                                    <div class="key-label">
                                        <i class="fas fa-key"></i>
                                        <span>SPKI format — used for verifying actor signatures</span>
                                    </div>
                                </div>
                            </div>
                            <div class="column is-6">
                                <div class="field">
                                    <label class="field-label" for="private-key">Private Key</label>
                                    <div class="control">
                                        <InputTextArea id="private-key" @bind-Value="Model.PrivateKeyPem" class="textarea" rows="6" placeholder="-----BEGIN PRIVATE KEY-----&#10;MIIEvQIBADANBgkqhki...&#10;-----END PRIVATE KEY-----" style="-webkit-text-security: disc; text-security: disc;" />
                                    </div>
                                    <div class="key-label">
                                        <i class="fas fa-lock"></i>
                                        <span>PKCS#8 format — used for signing actor activities</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (CurrentUser.IsAdmin())
        {
            <div class="column is-12">
                <div class="admin-advanced-section">
                    <div class="admin-section-header">
                        <i class="fas fa-shield-alt admin-section-icon"></i>
                        <span class="admin-section-title">Advanced (Admin Only)</span>
                    </div>

                    <div class="columns">
                        <div class="column is-6">
                            <div class="field">
                                <label class="field-label" for="linkedInOrgId">LinkedIn Organization ID</label>
                                <div class="control">
                                    <InputText id="linkedInOrgId" @bind-Value="Model!.LinkedInOrganizationId" class="input" placeholder="e.g. 12345678" />
                                </div>
                                <p class="help-text">Numeric LinkedIn Organization ID for certification integration</p>
                            </div>
                        </div>

                        <div class="column is-6">
                            <div class="field">
                                <label class="field-label" for="ownerGroup">Owner (Group)</label>
                                <div class="control">
                                    <div class="select is-fullwidth">
                                        <select id="ownerGroup" @bind="Model!.OwnerId">
                                            <option value="">Select a group...</option>
                                            @foreach (var group in availableGroups)
                                            {
                                                <option value="@group.Id">@group.Name</option>
                                            }
                                        </select>
                                    </div>
                                </div>
                                <p class="help-text">Assign or reassign the group that owns this issuer</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="form-actions">
            <div class="control">
                <button type="submit" class="button is-primary submit-button" disabled="@isSubmitting">
                    @if (isSubmitting)
                    {
                        <span class="icon is-small">
                            <i class="fas fa-spinner fa-spin"></i>
                        </span>
                        <span>Creating...</span>
                    }
                    else
                    {
                        <span class="icon">
                            <i class="fas fa-plus"></i>
                        </span>
                         @if (string.IsNullOrEmpty(ActorId))
                        {
                            <span>Create Actor</span>
                        } else {
                            <span>Update Actor</span>
                        }
                    }
                </button>
            </div>
            <div class="control">
                <button type="button" @onclick="ClearForm" class="button is-light">
                    <span class="icon">
                        <i class="fas fa-undo"></i>
                    </span>
                    <span>Clear Form</span>
                </button>
            </div>
        </div>
    </EditForm>
</div>

@if (showRegenerateModal)
{
    <div class="modal-overlay">
        <div class="modal-card">
            <div class="modal-card-head">
                <span class="modal-icon"><i class="fas fa-exclamation-circle"></i></span>
                <span class="modal-title">Regenerate Signing Keys?</span>
            </div>
            <div class="modal-card-body">
                <p>You are about to replace this issuer's cryptographic key pair. This is a <strong>destructive action</strong> that cannot be undone.</p>
                <div class="modal-warning-list">
                    <ul>
                        <li>Existing followers will no longer be able to verify your signatures</li>
                        <li>Previously signed badges may fail verification</li>
                        <li>Federation with other servers may be disrupted until they re-fetch your keys</li>
                    </ul>
                </div>
                <p>Only proceed if you understand the consequences.</p>
            </div>
            <div class="modal-card-foot">
                <button type="button" class="button" @onclick="CancelRegenerate">Cancel</button>
                <button type="button" class="button is-danger" @onclick="ConfirmRegenerateKeyPair">
                    <span class="icon is-small"><i class="fas fa-sync-alt"></i></span>
                    <span>Yes, Regenerate Keys</span>
                </button>
            </div>
        </div>
    </div>
}

@if (!string.IsNullOrEmpty(ActorId))
{
    <div class="form-section">
        <div class="form-header">
            <h2 class="form-title">Followed Issuers</h2>
        </div>
        @if (FollowedIssuers != null && FollowedIssuers.Any())
        {
            <ul>
                @foreach (var issuer in FollowedIssuers)
                {
                    <li>@issuer.Name - @issuer.Url</li>
                }
            </ul>
        }
        else
        {
            <p>No issuers followed yet.</p>
        }

        <div class="field">
            <label class="label">Issuer URL</label>
            <div class="control">
                <input class="input" @bind="newIssuerUrl" placeholder="https://badgefed-instance-domain.com/@@issuer" />
            </div>
        </div>

        <button type="button" class="button is-primary" @onclick="FollowIssuer">
            Follow
        </button>
        @if (!string.IsNullOrEmpty(issuerValidationMessage))
        {
            <p>@issuerValidationMessage</p>
        }
    </div>
}
  
@code {
    [Parameter]
    public string ActorId { get; set; }

    private Actor? Model = new();
    private IBrowserFile? selectedFile;
    private string? imagePreview;
    private string? errorMessage;
    private bool isSubmitting = false;
    private bool isAtIssuerLimit;
    private string? upgradeUrl;
    private ElementReference fileInput;
    private List<FollowedIssuer> FollowedIssuers = new();
    private string newIssuerUrl = string.Empty;
    private bool isIssuerValid;
    private string issuerValidationMessage;
    private bool showAdvancedSettings = false;
    private bool showRegenerateModal = false;
    private List<UserGroup> availableGroups = new();
    private bool usernameManuallyEdited = false;

    protected override async Task OnInitializedAsync()
    {
        if (IsLimitedManager() && string.IsNullOrEmpty(ActorId))
        {
            var actorList = LocalDbService.GetActors($"OwnerId = '{CurrentUser.GetGroupId()}'");
            var hasSubscription = await CurrentUser.HasActiveSubscription();
            isAtIssuerLimit = !hasSubscription && actorList.Count >= OpenRegistrationService.MaxIssuersForLimitedManager;
            if (isAtIssuerLimit)
                upgradeUrl = await BillingService.GetCheckoutUrl(CurrentUser.GetGroupId(), "/admin/actors/create");
        }
    }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(ActorId)) {
            var id = long.Parse(ActorId);
            Model = LocalDbService.GetActorById(id);

            // initialize domain based on request host
        }

        if (string.IsNullOrEmpty(Model.Domain))
        {
            Model.Domain = HttpContextAccessor?.HttpContext?.Request?.Host.Value;
        }

        // Load groups for admin owner assignment
        if (CurrentUser.IsAdmin())
        {
            availableGroups = LocalDbService.GetAllUserGroups();
        }

        // Initialize socials list if null
        if (Model.Socials == null)
        {
            Model.Socials = new List<SocialUri>();
        }

        // Ensure we have at least 3 empty social entries for the UI
        while (Model.Socials.Count < 3)
        {
            Model.Socials.Add(new SocialUri());
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(ActorId))
        {
            var actor = LocalDbService.GetActorById(long.Parse(ActorId));
            if (actor != null)
            {
                FollowedIssuers = LocalDbService.GetFollowedIssuers(actor.Id);
            }
        }
    }

    private void ClearForm() 
    {
        Model = new();
        usernameManuallyEdited = false;
        // Initialize socials list for new model
        Model.Socials = new List<SocialUri>();
        while (Model.Socials.Count < 3)
        {
            Model.Socials.Add(new SocialUri());
        }
    }

    private void OnFullNameChanged()
    {
        if (!usernameManuallyEdited && string.IsNullOrEmpty(ActorId))
        {
            Model!.Username = NormalizeToUsername(Model!.FullName);
        }
    }

    private void OnUsernameChanged()
    {
        if (string.IsNullOrEmpty(Model?.Username))
        {
            // User cleared the username — re-enable auto-suggestion
            usernameManuallyEdited = false;
            Model!.Username = NormalizeToUsername(Model.FullName);
        }
        else if (Model!.Username != NormalizeToUsername(Model.FullName))
        {
            usernameManuallyEdited = true;
        }
    }

    private static string NormalizeToUsername(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "";

        // Strip diacritics
        var normalized = name.Normalize(System.Text.NormalizationForm.FormD);
        var sb = new System.Text.StringBuilder();
        foreach (var c in normalized)
        {
            if (System.Globalization.CharUnicodeInfo.GetUnicodeCategory(c)
                != System.Globalization.UnicodeCategory.NonSpacingMark)
                sb.Append(c);
        }
        var ascii = sb.ToString().Normalize(System.Text.NormalizationForm.FormC);

        var lower = ascii.ToLowerInvariant();
        // Replace whitespace with dots
        var dotted = System.Text.RegularExpressions.Regex.Replace(lower, @"\s+", ".");
        // Keep only alphanumeric, dots, hyphens, underscores
        var clean = System.Text.RegularExpressions.Regex.Replace(dotted, @"[^a-z0-9.\-_]", "");
        // Collapse consecutive separators
        clean = System.Text.RegularExpressions.Regex.Replace(clean, @"[.\-_]{2,}", ".");
        // Trim leading/trailing separators
        clean = clean.Trim('.', '-', '_');
        // Cap at 50 chars
        return clean.Length > 50 ? clean[..50] : clean;
    }

    private bool HasKeys()
    {
        return !string.IsNullOrWhiteSpace(Model?.PublicKeyPem);
    }

    private bool HasPrivateKey()
    {
        return !string.IsNullOrWhiteSpace(Model?.PrivateKeyPem);
    }

    private void ToggleAdvancedSettings()
    {
        showAdvancedSettings = !showAdvancedSettings;
    }

    private void ShowRegenerateConfirmation()
    {
        showRegenerateModal = true;
    }

    private void CancelRegenerate()
    {
        showRegenerateModal = false;
    }

    private async Task ConfirmRegenerateKeyPair()
    {
        showRegenerateModal = false;
        await GenerateKeyPair();
    }

    private async Task GenerateAndSaveKeyPair()
    {
        await GenerateKeyPair();
    }

    private async Task GenerateKeyPair()
    {
        var keyPair = await CryptoService.GenerateKeyPairAsync();
        Model.PublicKeyPem = keyPair.PublicKeyPem;
        Model.PrivateKeyPem = keyPair.PrivateKeyPem;
        StateHasChanged();
    }

    private async Task HandleFileSelection(InputFileChangeEventArgs e)
    {
        errorMessage = null;
        selectedFile = e.File;
        
        if (selectedFile.Size > 2 * 1024 * 1024) // 2MB limit
        {
            errorMessage = "File size exceeds 2MB limit.";
            selectedFile = null;
            return;
        }

        var format = "image/jpeg";
        var resizedImage = await selectedFile.RequestImageFileAsync(format, 300, 300);
        var buffer = new byte[resizedImage.Size];
        await resizedImage.OpenReadStream().ReadAsync(buffer);
        
        imagePreview = $"data:{format};base64,{Convert.ToBase64String(buffer)}";
    }

    private bool IsLimitedManager() =>
        CurrentUser.GetRole().Equals(OpenRegistrationService.LimitedManagerRole, StringComparison.OrdinalIgnoreCase);

    private async Task HandleValidSubmit()
    {
        if (isAtIssuerLimit && string.IsNullOrEmpty(ActorId))
        {
            errorMessage = "You have reached your issuer limit. Please upgrade your plan to create more issuers.";
            return;
        }
        isSubmitting = true;
        try
        {
            // Auto-generate keys if none were provided
            if (string.IsNullOrWhiteSpace(Model.PublicKeyPem) || string.IsNullOrWhiteSpace(Model.PrivateKeyPem))
            {
                var keyPair = await CryptoService.GenerateKeyPairAsync();
                Model.PublicKeyPem = keyPair.PublicKeyPem;
                Model.PrivateKeyPem = keyPair.PrivateKeyPem;
            }

            if (selectedFile != null)
            {
                var fileName = $"{Guid.NewGuid()}{Path.GetExtension(selectedFile.Name)}";
                var path = CustomAssetPathService.GetAvatarsPath();
                
                Directory.CreateDirectory(path);
                
                var fullPath = Path.Combine(path, fileName);
                
                using var stream = selectedFile.OpenReadStream(2 * 1024 * 1024);
                using var fileStream = new FileStream(fullPath, FileMode.Create);
                await stream.CopyToAsync(fileStream);
                
                Model.AvatarPath = CustomAssetPathService.GetAvatarUrl(fileName);
            }

            // Clean up empty social entries before saving
            if (Model?.Socials != null)
            {
                Model.Socials = Model.Socials
                    .Where(s => !string.IsNullOrWhiteSpace(s.Type) && !string.IsNullOrWhiteSpace(s.Uri))
                    .ToList();
            }

            // Admin can set OwnerId via the advanced section; non-admins use their own group
            if (!CurrentUser.IsAdmin() || string.IsNullOrEmpty(Model.OwnerId))
            {
                Model.OwnerId = CurrentUser.GetGroupId();
            }
            
            LocalDbService.UpsertActor(Model);
            NavigationManager.NavigateTo("/admin/actors");
            
            Model = new();
            selectedFile = null;
            imagePreview = null;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error creating actor: {ex.Message}";
            Console.WriteLine(ex);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private async Task FollowIssuer()
    {
        try
        {
            var fediverseInfo = await FollowService.FollowIssuer(Model, newIssuerUrl);

            if (fediverseInfo != null)
            {
                isIssuerValid = true;
                issuerValidationMessage = $"Issuer found: {fediverseInfo.Name}";

                if (!string.IsNullOrEmpty(ActorId) && isIssuerValid)
                {
                    var actorId = long.Parse(ActorId);
                    var issuer = new FollowedIssuer
                    {
                        Name = fediverseInfo.Name, 
                        Url = newIssuerUrl,
                        Inbox = fediverseInfo.Inbox,
                        Outbox = fediverseInfo.Outbox,
                        ActorId = actorId,
                        AvatarUri = fediverseInfo.Icon?.Url ?? string.Empty
                    };

                    LocalDbService.UpsertFollowedIssuer(issuer);
                    FollowedIssuers = LocalDbService.GetFollowedIssuers(actorId);

                    newIssuerUrl = string.Empty;
                    issuerValidationMessage = $"Issuer {fediverseInfo.Name} followed!";
                    isIssuerValid = false;
                }
            } else {
                issuerValidationMessage = "⚠️ Could not retrieve the actor information. Check the URL is a valid fediverse actor.";
                return;
            }
        }
        catch (Exception ex)
        {
            issuerValidationMessage = $"⚠️ Could not validate url. {ex.Message}";
            return;
        }
    }

    private Dictionary<string, string> GetCustomThemes()
    {
        var customThemes = new Dictionary<string, string>();
        var themesPath = CustomAssetPathService.GetThemesPath();
        
        if (Directory.Exists(themesPath))
        {
            var cssFiles = Directory.GetFiles(themesPath, "*.css")
                .Where(f => !Path.GetFileNameWithoutExtension(f).Equals("default", StringComparison.OrdinalIgnoreCase) &&
                           !Path.GetFileNameWithoutExtension(f).Equals("ocean", StringComparison.OrdinalIgnoreCase) &&
                           !Path.GetFileNameWithoutExtension(f).Equals("forest", StringComparison.OrdinalIgnoreCase) &&
                           !Path.GetFileNameWithoutExtension(f).Equals("sunset", StringComparison.OrdinalIgnoreCase));
            
            foreach (var file in cssFiles)
            {
                var fileName = Path.GetFileNameWithoutExtension(file);
                var displayName = fileName.Replace("-", " ").Replace("_", " ");
                // Capitalize first letter of each word
                displayName = string.Join(" ", displayName.Split(' ').Select(word => 
                    char.ToUpper(word[0]) + word.Substring(1).ToLower()));
                customThemes.Add(fileName, $"{displayName} (Custom)");
            }
        }
        
        return customThemes;
    }

    // Social Links Helper Methods
    private string GetSocialType(int index)
    {
        if (Model?.Socials != null && index < Model.Socials.Count)
        {
            return Model.Socials[index]?.Type ?? "";
