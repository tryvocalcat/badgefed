@page "/admin/badge-record/{RecordIdParam}"
@using BadgeFed.Models
@using BadgeFed.Services
@using Microsoft.AspNetCore.Authorization
@inject NavigationManager NavigationManager
@inject LocalScopedDb LocalDbService
@inject ILogger<AdminBadgeRecordView> Logger
@rendermode InteractiveServer

@layout BadgeFed.Components.Layouts.AdminLayout

@attribute [Authorize(Roles = "admin, manager, manager-limited")]

<div class="container">
    <nav class="breadcrumb" aria-label="breadcrumbs">
        <ul>
            <li><a href="/admin">Dashboard</a></li>
            <li class="is-active"><a href="#" aria-current="page">Badge Record View</a></li>
        </ul>
    </nav>

    @if (badgeRecord == null)
    {
        <div class="notification is-warning">
            <p>Loading badge record...</p>
        </div>
    }
    else
    {
        <div class="box">
            <div class="level mb-4">
                <div class="level-left">
                    <div class="level-item">
                        <h1 class="title is-4">Badge Record Details</h1>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="notification is-danger">
                    <button class="delete" @onclick="() => errorMessage = string.Empty"></button>
                    <p>@errorMessage</p>
                </div>
            }

            <div class="columns">
                <!-- Badge Image Column -->
                @if (!string.IsNullOrEmpty(badgeRecord.FullImageUrl))
                {
                    <div class="column is-3">
                        <div class="box has-text-centered">
                            <figure class="image">
                                <img src="@badgeRecord.FullImageUrl" alt="@badgeRecord.ImageAltText" style="max-height: 200px; object-fit: contain;" />
                            </figure>
                            @if (!string.IsNullOrEmpty(badgeRecord.ImageAltText))
                            {
                                <p class="is-size-7 has-text-grey mt-2">
                                    <strong>Alt Text:</strong> @badgeRecord.ImageAltText
                                </p>
                            }
                        </div>
                    </div>
                }

                <!-- Main Details Column -->
                <div class="column">
                    <!-- Basic Information -->
                    <div class="box">
                        <h2 class="subtitle is-5 mb-3">
                            <span class="icon-text">
                                <span class="icon">
                                    <i class="fas fa-info-circle"></i>
                                </span>
                                <span>Basic Information</span>
                            </span>
                        </h2>
                        
                        <div class="field is-horizontal">
                            <div class="field-label is-normal">
                                <label class="label">Record ID</label>
                            </div>
                            <div class="field-body">
                                <div class="field">
                                    <p class="control">
                                        <input class="input" readonly value="@badgeRecord.Id" />
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="field is-horizontal">
                            <div class="field-label is-normal">
                                <label class="label">Title</label>
                            </div>
                            <div class="field-body">
                                <div class="field">
                                    <p class="control">
                                        <input class="input" readonly value="@badgeRecord.Title" />
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="field is-horizontal">
                            <div class="field-label is-normal">
                                <label class="label">Type</label>
                            </div>
                            <div class="field-body">
                                <div class="field">
                                    <p class="control">
                                        <input class="input" readonly value="@(badgeRecord.Badge?.BadgeType ?? string.Empty)" />
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="field is-horizontal">
                            <div class="field-label is-normal">
                                <label class="label">Visibility</label>
                            </div>
                            <div class="field-body">
                                <div class="field">
                                    <span class="tag is-info">@badgeRecord.Visibility</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Description -->
                    @if (!string.IsNullOrEmpty(badgeRecord.Description))
                    {
                        <div class="box">
                            <h2 class="subtitle is-5 mb-2">Description</h2>
                            <div class="content">
                                <p>@badgeRecord.Description</p>
                            </div>
                        </div>
                    }

                    <!-- Earning Criteria -->
                    @if (!string.IsNullOrEmpty(badgeRecord.EarningCriteria))
                    {
                        <div class="box">
                            <h2 class="subtitle is-5 mb-2">Earning Criteria</h2>
                            <div class="content">
                                <p>@badgeRecord.EarningCriteria</p>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <!-- Issuer Information -->
            <div class="box">
                <h2 class="subtitle is-5 mb-3">
                    <span class="icon-text">
                        <span class="icon">
                            <i class="fas fa-user-tie"></i>
                        </span>
                        <span>Issuer Information</span>
                    </span>
                </h2>
                
                <div class="field is-horizontal">
                    <div class="field-label is-normal">
                        <label class="label">Issued By URI</label>
                    </div>
                    <div class="field-body">
                        <div class="field">
                            <p class="control">
                                <input class="input" readonly value="@badgeRecord.IssuedBy" />
                            </p>
                        </div>
                    </div>
                </div>

                @if (badgeRecord.Actor != null && !string.IsNullOrEmpty(badgeRecord.Actor.Username))
                {
                    <div class="field is-horizontal">
                        <div class="field-label is-normal">
                            <label class="label">Issuer Handle</label>
                        </div>
                        <div class="field-body">
                            <div class="field">
                                <p class="control">
                                    <input class="input" readonly value="@badgeRecord.IssuerFediverseHandle" />
                                </p>
                            </div>
                        </div>
                    </div>
                }

                <div class="field is-horizontal">
                    <div class="field-label is-normal">
                        <label class="label">Is External</label>
                    </div>
                    <div class="field-body">
                        <div class="field">
                            <span class="tag @(badgeRecord.IsExternal ? "is-warning" : "is-success")">
                                @(badgeRecord.IsExternal ? "External" : "Internal")
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recipient Information -->
            <div class="box">
                <h2 class="subtitle is-5 mb-3">
                    <span class="icon-text">
                        <span class="icon">
                            <i class="fas fa-user"></i>
                        </span>
                        <span>Recipient Information</span>
                    </span>
                </h2>
                
                <div class="field is-horizontal">
                    <div class="field-label is-normal">
                        <label class="label">Recipient Name</label>
                    </div>
                    <div class="field-body">
                        <div class="field">
                            <p class="control">
                                <input class="input" readonly value="@badgeRecord.IssuedToName" />
                            </p>
                        </div>
                    </div>
                </div>

                <div class="field is-horizontal">
                    <div class="field-label is-normal">
                        <label class="label">Recipient Email</label>
                    </div>
                    <div class="field-body">
                        <div class="field">
                            <p class="control">
                                <input class="input" readonly value="@badgeRecord.IssuedToEmail" />
                            </p>
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(badgeRecord.IssuedToSubjectUri))
                {
                    <div class="field is-horizontal">
                        <div class="field-label is-normal">
                            <label class="label">Recipient Subject URI</label>
                        </div>
                        <div class="field-body">
                            <div class="field">
                                <p class="control">
                                    <input class="input" readonly value="@badgeRecord.IssuedToSubjectUri" />
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Dates and Status -->
            <div class="box">
                <h2 class="subtitle is-5 mb-3">
                    <span class="icon-text">
                        <span class="icon">
                            <i class="fas fa-calendar"></i>
                        </span>
                        <span>Dates & Status</span>
                    </span>
                </h2>
                
                <div class="columns">
                    <div class="column is-6">
                        <div class="field is-horizontal">
                            <div class="field-label is-normal">
                                <label class="label">Issued On</label>
                            </div>
                            <div class="field-body">
                                <div class="field">
                                    <p class="control">
                                        <input class="input" readonly value="@badgeRecord.IssuedOn.ToString("yyyy-MM-dd HH:mm:ss")" />
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="column is-6">
                        <div class="field is-horizontal">
                            <div class="field-label is-normal">
                                <label class="label">Last Updated</label>
                            </div>
                            <div class="field-body">
                                <div class="field">
                                    <p class="control">
                                        <input class="input" readonly value="@(badgeRecord.LastUpdated?.ToString("yyyy-MM-dd HH:mm:ss") ?? "Never")" />
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="columns">
                    <div class="column is-6">
                        <div class="field is-horizontal">
                            <div class="field-label is-normal">
                                <label class="label">Accepted On</label>
                            </div>
                            <div class="field-body">
                                <div class="field">
                                    <p class="control">
                                        <input class="input" readonly value="@(badgeRecord.AcceptedOn?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")" />
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="column is-6">
                        <div class="field is-horizontal">
                            <div class="field-label is-normal">
                                <label class="label">Notified Of Grant</label>
                            </div>
                            <div class="field-body">
                                <div class="field">
                                    <span class="tag @(badgeRecord.NotifiedOfGrant ? "is-success" : "is-light")">
                                        @(badgeRecord.NotifiedOfGrant ? "Yes" : "No")
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                @if (badgeRecord.BoostedOn.HasValue)
                {
                    <div class="field is-horizontal">
                        <div class="field-label is-normal">
                            <label class="label">Boosted On</label>
                        </div>
                        <div class="field-body">
                            <div class="field">
                                <p class="control">
                                    <input class="input" readonly value="@badgeRecord.BoostedOn.Value.ToString("yyyy-MM-dd HH:mm:ss")" />
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Additional Information -->
            <div class="box">
                <h2 class="subtitle is-5 mb-3">
                    <span class="icon-text">
                        <span class="icon">
                            <i class="fas fa-tags"></i>
                        </span>
                        <span>Additional Information</span>
                    </span>
                </h2>
                
                @if (!string.IsNullOrEmpty(badgeRecord.FingerPrint))
                {
                    <div class="field is-horizontal">
                        <div class="field-label is-normal">
                            <label class="label">Fingerprint</label>
                        </div>
                        <div class="field-body">
                            <div class="field">
                                <p class="control">
                                    <textarea class="textarea is-small" readonly rows="2">@badgeRecord.FingerPrint</textarea>
                                </p>
                            </div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(badgeRecord.NoteId))
                {
                    <div class="field is-horizontal">
                        <div class="field-label is-normal">
                            <label class="label">Note ID</label>
                        </div>
                        <div class="field-body">
                            <div class="field">
                                <p class="control">
                                    <textarea class="textarea is-small" readonly rows="2">@badgeRecord.NoteId</textarea>
                                </p>
                            </div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(badgeRecord.AcceptKey))
                {
                    <div class="field is-horizontal">
                        <div class="field-label is-normal">
                            <label class="label">Accept Key</label>
                        </div>
                        <div class="field-body">
                            <div class="field">
                                <p class="control">
                                    <input class="input" readonly value="@badgeRecord.AcceptKey" />
                                </p>
                            </div>
                        </div>
                    </div>
                }

                @if (!string.IsNullOrEmpty(badgeRecord.Hashtags))
                {
                    <div class="field is-horizontal">
                        <div class="field-label is-normal">
                            <label class="label">Hashtags</label>
                        </div>
                        <div class="field-body">
                            <div class="field">
                                @foreach (var tag in badgeRecord.HashtagsList)
                                {
                                    <span class="tag is-light mr-2">@tag</span>
                                }
                            </div>
                        </div>
                    </div>
                }

                @if (badgeRecord.Badge != null)
                {
                    <div class="field is-horizontal">
                        <div class="field-label is-normal">
                            <label class="label">Badge Class ID</label>
                        </div>
                        <div class="field-body">
                            <div class="field">
                                <p class="control">
                                    <input class="input" readonly value="@badgeRecord.Badge.Id" />
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>

        </div>
    }
</div>

@code {
    [Parameter]
    public string RecordIdParam { get; set; } = "";

    private BadgeRecord? badgeRecord;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (!long.TryParse(RecordIdParam, out var recordId))
            {
                errorMessage = "Invalid record ID format";
                return;
            }

            var records = LocalDbService.GetBadgeRecords(recordId);
            badgeRecord = records.FirstOrDefault();

            if (badgeRecord == null)
            {
                errorMessage = $"Badge record with ID {recordId} not found";
                return;
            }

            // Load actor information if available
            if (!string.IsNullOrEmpty(badgeRecord.IssuedBy))
            {
                badgeRecord.Actor = LocalDbService.GetActorByFilter($"Uri = \"{badgeRecord.IssuedBy}\"") ?? new Models.Actor();
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading badge record");
            errorMessage = $"An error occurred while loading the badge record: {ex.Message}";
        }
    }
}
