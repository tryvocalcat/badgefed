        var command = connection.CreateCommand();
        command.CommandText = @"
            SELECT COUNT(*)
            FROM BadgeRecord AS br
            INNER JOIN Badge AS b ON br.BadgeId = b.Id
            WHERE b.OwnerId = @OwnerId;
        ";
        command.Parameters.AddWithValue("@OwnerId", ownerGroupId);

