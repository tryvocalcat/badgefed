    private BadgeRecord ReaderToBadgeRecord(System.Data.IDataReader reader)
    {
        return new BadgeRecord
        {
            Id = reader.GetInt64(0),                                          // Id
            Title = reader.GetString(1),                                      // Title
            IssuedBy = reader.GetString(2),                                   // IssuedBy
            Description = reader.IsDBNull(3) ? "" : reader.GetString(3),      // Description
            Image = reader.IsDBNull(4) ? "" : reader.GetString(4),            // Image
            ImageAltText = reader.IsDBNull(5) ? "" : reader.GetString(5),     // ImageAltText
            EarningCriteria = reader.IsDBNull(6) ? "" : reader.GetString(6),  // EarningCriteria
            Hashtags = reader.IsDBNull(7) ? "" : reader.GetString(7),         // Hashtags
            IssuedOn = reader.GetDateTime(8),                                 // IssuedOn
            IssuedToEmail = reader.IsDBNull(9) ? "" : reader.GetString(9),    // IssuedToEmail
            IssuedToName = reader.IsDBNull(10) ? "" : reader.GetString(10),   // IssuedToName
            IssuedToSubjectUri = reader.IsDBNull(11) ? "" : reader.GetString(11), // IssuedToSubjectUri
            AcceptedOn = reader.IsDBNull(12) ? null : reader.GetDateTime(12), // AcceptedOn
            LastUpdated = reader.IsDBNull(13) ? null : reader.GetDateTime(13), // LastUpdated
            FingerPrint = reader.IsDBNull(14) ? "" : reader.GetString(14),    // FingerPrint
            AcceptKey = reader.IsDBNull(15) ? "" : reader.GetString(15),      // AcceptKey
            NoteId = reader.IsDBNull(17) ? "" : reader.GetString(17)          // NoteId
        };
    }
    
    private async Task LoadAdminResourcesHtml()
    {
        try
        {
            var filePath = Path.Combine(Environment.ContentRootPath, "assets", "static", "admin-resources.html");
            if (File.Exists(filePath))
            {
                adminResourcesHtml = await File.ReadAllTextAsync(filePath);
            }
            else
            {
                // Fallback HTML if file doesn't exist
                adminResourcesHtml = @"";
            }
        }
        catch (Exception ex)
        {
            adminResourcesHtml = @"";
        }
    }

