    private string ExtractActivityPubHandle(string authorUrl)
    {
        try
        {
            var uri = new Uri(authorUrl);
            // Extract username from path like /users/mapache
            var pathParts = uri.PathAndQuery.Split('/', StringSplitOptions.RemoveEmptyEntries);
            var username = pathParts.Length >= 2 && pathParts[0] == "users" ? pathParts[1] : "unknown";
            
            // Get domain from host
            var domain = uri.Host;
            
            return $"@{username}@{domain}";
        }
        catch
        {
            return "@unknown";
        }
    }

    private string ExtractIssuerName(string issuerUrl)
    {
        try
        {
            var uri = new Uri(issuerUrl);
            // Extract from path like /actors/communitycredentials.org/somostech.community or /actors/domain
            var pathParts = uri.PathAndQuery.Split('/', StringSplitOptions.RemoveEmptyEntries);
            
            if (pathParts.Length >= 2 && pathParts[0] == "actors")
            {
                // Get the last part after /actors/
                var issuerName = string.Join("/", pathParts.Skip(1));
                return issuerName;
            }
            
            // Fallback to host
            return uri.Host;
        }
        catch
        {
            return "Unknown Issuer";
        }
    }
