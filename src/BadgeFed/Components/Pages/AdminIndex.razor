    private string GetSetupStepClass(int step)
    {
        if (ShowIssuerSetupPrompt)
        {
            return step == 1 ? "is-active" : string.Empty;
        }

        if (ShowBadgeSetupPrompt)
        {
            return step <= 2 ? (step == 2 ? "is-active" : "is-complete") : string.Empty;
        }

        if (ShowGrantSetupPrompt)
        {
            return step <= 3 ? (step == 3 ? "is-active" : "is-complete") : string.Empty;
        }

        return string.Empty;
    }

    private List<CommentItem> GetLastComments(int limit, string? ownerGroupId = null)
    {
        var comments = new List<CommentItem>();
        using var connection = LocalDbService.GetConnection();
        connection.Open();

        var command = connection.CreateCommand();
        command.CommandText = ownerGroupId == null
            ? @"
            SELECT Id, NoteId, AuthorId, CreatedAt FROM BadgeRecordComment 
            ORDER BY CreatedAt DESC 
            LIMIT @Limit"
            : @"
            SELECT c.Id, c.NoteId, c.AuthorId, c.CreatedAt
            FROM BadgeRecordComment AS c
            INNER JOIN BadgeRecord AS br ON c.BadgeRecordId = br.Id
            INNER JOIN Badge AS b ON br.BadgeId = b.Id
            WHERE b.OwnerId = @OwnerId
            ORDER BY c.CreatedAt DESC
            LIMIT @Limit";
        command.Parameters.AddWithValue("@Limit", limit);
        if (ownerGroupId != null)
        {
            command.Parameters.AddWithValue("@OwnerId", ownerGroupId);
        }

        using var reader = command.ExecuteReader();
        while (reader.Read())
        {
            comments.Add(new CommentItem
            {
                Id = reader.GetInt64(0),
                NoteId = reader.GetString(1),
                AuthorId = reader.GetString(2),
                CreatedAt = DateTime.Parse(reader.GetString(3))
            });
        }

        return comments;
    }

    private List<BadgeRecord> GetLastAcceptedBadges(int limit, string? ownerGroupId = null)
    {
        var records = new List<BadgeRecord>();
        using var connection = LocalDbService.GetConnection();
        connection.Open();

        var command = connection.CreateCommand();
        command.CommandText = ownerGroupId == null
            ? @"
            SELECT Id, Title, IssuedBy, Description, Image, ImageAltText, EarningCriteria, 
                   Hashtags, IssuedOn, IssuedToEmail, IssuedToName, IssuedToSubjectUri, 
                   AcceptedOn, LastUpdated, FingerPrint, AcceptKey, BadgeId, NoteId
            FROM BadgeRecord 
            WHERE AcceptedOn IS NOT NULL
            ORDER BY AcceptedOn DESC
            LIMIT @Limit"
            : @"
            SELECT br.Id, br.Title, br.IssuedBy, br.Description, br.Image, br.ImageAltText, br.EarningCriteria,
                   br.Hashtags, br.IssuedOn, br.IssuedToEmail, br.IssuedToName, br.IssuedToSubjectUri,
                   br.AcceptedOn, br.LastUpdated, br.FingerPrint, br.AcceptKey, br.BadgeId, br.NoteId
            FROM BadgeRecord AS br
            INNER JOIN Badge AS b ON br.BadgeId = b.Id
            WHERE br.AcceptedOn IS NOT NULL AND b.OwnerId = @OwnerId
            ORDER BY br.AcceptedOn DESC
            LIMIT @Limit";
        command.Parameters.AddWithValue("@Limit", limit);
        if (ownerGroupId != null)
        {
            command.Parameters.AddWithValue("@OwnerId", ownerGroupId);
        }

        using var reader = command.ExecuteReader();
        while (reader.Read())
